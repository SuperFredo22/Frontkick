---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles');
const articles = all
  .filter(a => a.data.category === 'actualite')
  .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));

const sportEmojis: Record<string, string> = {
  mma: '🥊', boxe: '🥊', kickboxing: '🦵', 'muay-thai': '🦵',
  grappling: '🤼', karate: '🥋', equipement: '🛒',
};
---
<Base title="Actualités — Front Kick" description="Toutes les actualités des sports de combat.">
  <div class="section">
    <h1 style="font-size:2rem; font-weight:800; margin-bottom:0.5rem;">📰 Actualités</h1>
    <p style="color:var(--text-muted); margin-bottom:2rem;">Les dernières news des sports de combat.</p>

    {articles.length > 0 ? (
      <div class="articles-grid">
        {articles.map(a => (
          <a href={`/articles/${a.slug}`} class="article-card">
            <div class="card-tags">
              <span class="tag red">{sportEmojis[a.data.sport] || '🥊'} {a.data.sport.toUpperCase()}</span>
              <span class="tag">Actualité</span>
            </div>
            <div class="card-title" set:html={a.data.title}></div>
            <div class="card-excerpt">{a.data.excerpt}</div>
            <div class="card-meta">
              <span>{a.data.date}</span>
              <span class="card-read-link">Lire →</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div style="text-align:center; padding:4rem 0; color:var(--text-muted);">
        <div style="font-size:3rem; margin-bottom:1rem;">🔜</div>
        <p>Les actualités arrivent bientôt.</p>
        <p style="margin-top:0.5rem; font-size:0.85rem;">En attendant, retrouve tous nos articles ci-dessous.</p>
        <a href="/guides" style="display:inline-block; margin-top:1.5rem; background:var(--red); color:white; padding:0.7rem 1.4rem; border-radius:8px; font-weight:700;">Voir tous les articles →</a>
      </div>
    )}
  </div>
</Base>
