---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles');
const articles = all
  .filter(a => a.data.category === 'actualite')
  .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));

const gradients: Record<string, string> = {
  mma: 'linear-gradient(135deg, #0F172A 0%, #1E88E5 100%)',
  boxe: 'linear-gradient(135deg, #7f1d1d 0%, #DC2626 100%)',
};
const emojis: Record<string, string> = {
  mma: '🥊', boxe: '🥊', kickboxing: '🦵', 'muay-thai': '🦵', grappling: '🤼',
};
---
<Base title="Actualités — Front Kick" description="Les dernières actualités des sports de combat.">
<div id="app">
  <div class="list-page">
    <div class="list-hero">
      <h1>📰 Actualités</h1>
      <p>Les dernières news des sports de combat.</p>
    </div>
    {articles.length > 0 ? (
      <div class="art-grid">
        {articles.map(a => (
          <a href={`/articles/${a.slug}`} class="art-card">
            <div class="art-image" style={`background: ${gradients[a.data.sport] || 'linear-gradient(135deg,#0F172A,#38BDF8)'}; display:flex; align-items:center; justify-content:center;`}>
              <span style="font-size:2.8rem;">{emojis[a.data.sport] || '🥊'}</span>
            </div>
            <div class="art-body">
              <div class="art-title-sm" set:html={a.data.title}></div>
              <div class="art-excerpt">{a.data.excerpt}</div>
              <div class="art-foot"><span>{a.data.date}</span></div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <span class="emoji">🔜</span>
        <h3>Actualités bientôt disponibles</h3>
        <p>Les news des sports de combat arrivent prochainement.</p>
        <a href="/guides" class="btn">📖 Voir les guides →</a>
      </div>
    )}
  </div>
</div>
</Base>
