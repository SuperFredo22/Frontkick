---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles');
const articles = all
  .filter(a => a.data.category === 'actualite')
  .sort((a, b) => {
    // Tri par date décroissante (les plus récents en premier)
    const da = new Date(a.data.date).getTime() || 0;
    const db = new Date(b.data.date).getTime() || 0;
    if (db !== da) return db - da;
    // Si même date ou date non parseable, featured en premier
    return (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0);
  });

const gradients: Record<string, string> = {
  mma:          'linear-gradient(135deg, #0F172A 0%, #1E88E5 100%)',
  boxe:         'linear-gradient(135deg, #7f1d1d 0%, #DC2626 100%)',
  kickboxing:   'linear-gradient(135deg, #064e3b 0%, #10B981 100%)',
  'muay-thai':  'linear-gradient(135deg, #78350f 0%, #F59E0B 100%)',
  grappling:    'linear-gradient(135deg, #1e3a8a 0%, #3B82F6 100%)',
  karate:       'linear-gradient(135deg, #1a1a2e 0%, #e94560 100%)',
  sanda:        'linear-gradient(135deg, #7c2d12 0%, #ea580c 100%)',
  lethwei:      'linear-gradient(135deg, #1c1917 0%, #a8a29e 100%)',
  savate:       'linear-gradient(135deg, #1e3a5f 0%, #2563EB 100%)',
  sambo:        'linear-gradient(135deg, #1a1a1a 0%, #dc2626 100%)',
  k1:           'linear-gradient(135deg, #1a1a2e 0%, #7C3AED 100%)',
  equipement:   'linear-gradient(135deg, #0F172A 0%, #38BDF8 100%)',
};
const emojis: Record<string, string> = {
  mma: '🥊', boxe: '🥊', kickboxing: '🦵', 'muay-thai': '🦵',
  grappling: '🤼', karate: '🥋', sanda: '🐉', lethwei: '💀',
  savate: '🇫🇷', sambo: '🇷🇺', k1: '⚡', equipement: '🛒',
};
const sportImages: Record<string, string> = {
  mma:          '/images/banners/mma.png',
  boxe:         '/images/banners/boxe.png',
  'muay-thai':  '/images/banners/muay-thai.png',
  grappling:    '/images/banners/grappling.png',
  karate:       '/images/banners/karate.png',
};
const catLabel: Record<string, string> = {
  'guide-debutant': 'Guide Débutant', 'conseil-entrainement': 'Conseil',
  'guide-equipement': 'Équipement', 'analyse': 'Analyse', 'actualite': 'Actualité', 'guide': 'Guide',
};
---
<Base title="Actualités — FightFocus" description="Les dernières actualités des sports de combat : UFC, MMA, boxe, kickboxing et plus.">
<div id="app">
  <div class="list-page">
    <div class="discipline-hero" style="background:linear-gradient(135deg,#7f1d1d 0%,#DC2626 100%);margin-bottom:32px;">
      <div class="discipline-hero__bg" style="background-image:url('/images/banners/boxe.png');"></div>
      <div class="discipline-hero__overlay"></div>
      <div class="discipline-hero__content">
        <div class="discipline-hero__label">FightFocus</div>
        <h1 class="discipline-hero__title">Actualités</h1>
        <p class="discipline-hero__desc">Les dernières news des sports de combat.</p>
      </div>
    </div>
    {articles.length > 0 ? (
      <div class="art-grid">
        {articles.map(a => (
          <a href={`/articles/${a.slug}`} class="art-card">
            <div class="art-image" style={`background: ${gradients[a.data.sport] || gradients.mma}; background-image: url('${sportImages[a.data.sport] ?? ''}'); background-size: cover; background-position: center; position:relative; overflow:hidden;`}>
              <span class="art-cat-tag">{catLabel[a.data.category] || a.data.category}</span>
            </div>
            <div class="art-body">
              <div class="art-title-sm" set:html={a.data.title}></div>
              <div class="art-excerpt">{a.data.excerpt}</div>
              <div class="art-foot">
                <span>{a.data.date}</span>
                <span class="atype t-guide">{a.data.sport}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h3>Actualités bientôt disponibles</h3>
        <p>Les news des sports de combat arrivent prochainement.</p>
        <a href="/guides" class="btn">Voir les guides →</a>
      </div>
    )}
  </div>
</div>
</Base>
