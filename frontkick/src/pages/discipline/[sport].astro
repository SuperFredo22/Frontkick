---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const sports = [
    'mma','boxe','kickboxing','muay-thai','grappling','karate',
    'sanda','lethwei','savate','sambo','k1'
  ];
  return sports.map(s => ({ params: { sport: s } }));
}

const { sport } = Astro.params;
const all = await getCollection('articles');
const sportAliases: Record<string, string[]> = {
  mma:          ['mma', 'ufc'],
  boxe:         ['boxe'],
  kickboxing:   ['kickboxing'],
  'muay-thai':  ['muay-thai'],
  grappling:    ['grappling', 'bjj', 'judo', 'wrestling'],
  karate:       ['karate', 'kyokushin'],
  sanda:        ['sanda', 'wushu'],
  lethwei:      ['lethwei'],
  savate:       ['savate'],
  sambo:        ['sambo'],
  k1:           ['k1', 'glory'],
};
const aliases = sportAliases[sport] || [sport];

function parseDate(d: string): number {
  const parsed = new Date(d);
  if (!isNaN(parsed.getTime())) return parsed.getTime();
  const y = d?.match(/\d{4}/);
  return y ? parseInt(y[0]) * 1000000 : 0;
}

// Sports reconnus : un article qui a déjà un sport précis différent ne doit jamais
// apparaître sur une autre page discipline via le slug matching (ex: lethwei-boxe-birmane
// ne doit pas s'afficher sur /discipline/boxe)
const knownSports = ['mma','boxe','kickboxing','muay-thai','grappling','karate','sanda','lethwei','savate','sambo','k1'];

const articles = all
  .filter(a => {
    if (a.data.sport === sport) return true;
    // Si l'article appartient déjà à une autre discipline précise → pas de slug matching
    if (knownSports.includes(a.data.sport) && a.data.sport !== sport) return false;
    if (['guide-equipement', 'guide-debutant', 'guide', 'analyse'].includes(a.data.category)) {
      return aliases.some(alias => {
        const slug = a.slug;
        const idx = slug.indexOf(alias);
        if (idx === -1) return false;
        const before = idx === 0 || slug[idx - 1] === '-';
        const after = idx + alias.length === slug.length || slug[idx + alias.length] === '-';
        return before && after;
      });
    }
    return false;
  })
  .sort((a, b) => {
    if (b.data.featured !== a.data.featured) return (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0);
    const aIsActu = a.data.category === 'actualite' ? 1 : 0;
    const bIsActu = b.data.category === 'actualite' ? 1 : 0;
    if (bIsActu !== aIsActu) return bIsActu - aIsActu;
    return parseDate(b.data.date) - parseDate(a.data.date);
  });

const labels: Record<string, string> = {
  mma: 'MMA', boxe: 'Boxe anglaise', kickboxing: 'Kickboxing',
  'muay-thai': 'Muay-Thaï', grappling: 'Grappling', karate: 'Karaté',
  sanda: 'Sanda (Wushu)', lethwei: 'Lethwei', savate: 'Savate Boxe Française',
  sambo: 'Sambo', k1: 'K-1 / Glory',
};
const emojis: Record<string, string> = {
  mma: '🥊', boxe: '🥊', kickboxing: '🦵', 'muay-thai': '🦵', grappling: '🤼', karate: '🥋',
  sanda: '🐉', lethwei: '💀', savate: '🇫🇷', sambo: '🇷🇺', k1: '⚡',
};
const sportImages: Record<string, string> = {
  mma: '/images/sports/mma.svg', boxe: '/images/sports/boxe.svg',
  kickboxing: '/images/sports/kickboxing.svg', 'muay-thai': '/images/sports/muay-thai.svg',
  grappling: '/images/sports/grappling.svg', karate: '/images/sports/karate.svg',
  sambo: '/images/sports/sambo.svg', savate: '/images/sports/savate.svg',
  sanda: '/images/sports/sanda.svg', lethwei: '/images/sports/lethwei.svg',
  k1: '/images/sports/k1.svg',
};
const gradients: Record<string, string> = {
  mma:          'linear-gradient(135deg, #0F172A 0%, #1E88E5 100%)',
  boxe:         'linear-gradient(135deg, #7f1d1d 0%, #DC2626 100%)',
  kickboxing:   'linear-gradient(135deg, #064e3b 0%, #10B981 100%)',
  'muay-thai':  'linear-gradient(135deg, #78350f 0%, #F59E0B 100%)',
  grappling:    'linear-gradient(135deg, #1e3a8a 0%, #3B82F6 100%)',
  karate:       'linear-gradient(135deg, #1a1a2e 0%, #e94560 100%)',
  sanda:        'linear-gradient(135deg, #7c2d12 0%, #ea580c 100%)',
  lethwei:      'linear-gradient(135deg, #1c1917 0%, #a8a29e 100%)',
  savate:       'linear-gradient(135deg, #1e3a5f 0%, #2563EB 100%)',
  sambo:        'linear-gradient(135deg, #1a1a1a 0%, #dc2626 100%)',
  k1:           'linear-gradient(135deg, #1a1a2e 0%, #7C3AED 100%)',
};
const descriptions: Record<string, string> = {
  mma: 'Guides, analyses et conseils pour les pratiquants de MMA.',
  boxe: 'Technique, équipement et actualités pour les boxeurs.',
  kickboxing: 'Tout sur le kickboxing : technique, entraînement, compétition.',
  'muay-thai': "L'art des 8 membres décrypté : clinch, coudes, genoux.",
  grappling: 'Soumissions, takedowns et positions au sol.',
  karate: 'Kata, kumite et philosophie du karaté.',
  sanda: "Le Sanda (Wushu Sanda) : l'art martial chinois de compétition qui mêle frappes et projections.",
  lethwei: "Le Lethwei birman : le sport de combat le plus brutal au monde, où les coups de tête sont autorisés.",
  savate: "La Savate, boxe française : l'art du pied et du poing, sport de combat typiquement français.",
  sambo: "Le Sambo russe : entre judo et lutte, une discipline redoutable au sol comme debout.",
  k1: "Le K-1 et le Glory : le kickboxing de haut niveau, frappe debout pure.",
};
const catLabel: Record<string, string> = {
  'guide-debutant':       'Guide Débutant',
  'conseil-entrainement': 'Conseil',
  'guide-equipement':     'Équipement',
  'guide':                'Guide',
  'analyse':              'Analyse',
  'actualite':            'Actualité',
  'guide':               'Guide',
};
const label = labels[sport] || sport;
const emoji = emojis[sport] || '🥊';
const gradient = gradients[sport] || gradients.mma;
const description = descriptions[sport] || `Guides et articles sur ${label}.`;
---
<Base title={`${label} — FightFocus`} description={description}>
<div id="app">
  <div class="list-page">
    <div class="discipline-hero" style={`background: ${gradient};`}>
      <div class="discipline-hero__bg" style={`background-image:url('${sportImages[sport] || '/images/sports/mma.svg'}');`}></div>
      <div class="discipline-hero__overlay"></div>
      <div class="discipline-hero__content">
        <div class="discipline-hero__label">Discipline</div>
        <h1 class="discipline-hero__title">{label}</h1>
        <p class="discipline-hero__desc">{description}</p>
      </div>
    </div>

    {articles.length > 0 ? (
      <div>
        {/* Article featured — le premier de la liste */}
        <a href={`/articles/${articles[0].slug}`} class="art-card art-card--featured">
          <div class="art-image art-image--featured" style={`background:${gradients[articles[0].data.sport] || gradient};background-image:url('${sportImages[articles[0].data.sport] ?? '/images/sports/default.svg'}');background-size:cover;background-position:center;position:relative;overflow:hidden;`}>
            <span class="art-cat-tag">{catLabel[articles[0].data.category] || articles[0].data.category}</span>
          </div>
          <div class="art-body art-body--featured">
            <div class="art-title-sm" style="font-size:1.25rem;margin-bottom:10px;" set:html={articles[0].data.title}></div>
            <div class="art-excerpt" style="font-size:0.9rem;line-height:1.6;margin-bottom:16px;">{articles[0].data.excerpt}</div>
            <div class="art-foot">
              <span>{articles[0].data.date}</span>
              <span class="read-more">Lire l'article →</span>
            </div>
          </div>
        </a>

        {/* Reste des articles */}
        {articles.slice(1).length > 0 && (
          <div class="art-grid" style="margin-top:24px;">
            {articles.slice(1).map(a => (
              <a href={`/articles/${a.slug}`} class="art-card">
                <div class="art-image" style={`background:${gradients[a.data.sport] || gradient};background-image:url('${sportImages[a.data.sport] ?? '/images/sports/default.svg'}');background-size:cover;background-position:center;position:relative;overflow:hidden;`}>
                  <span class="art-cat-tag">{catLabel[a.data.category] || a.data.category}</span>
                </div>
                <div class="art-body">
                  <div class="art-title-sm" set:html={a.data.title}></div>
                  <div class="art-excerpt">{a.data.excerpt}</div>
                  <div class="art-foot">
                    <span>{a.data.date}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    ) : (
      <div class="empty-state">
        <h3>Bientôt disponible</h3>
        <p>Les articles pour cette discipline arrivent prochainement. Revenez vite !</p>
        <a href="/" class="btn">← Retour à l'accueil</a>
      </div>
    )}
  </div>
</div>
</Base>
