---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(a => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = await getEntry('articles', slug as string);
if (!article) return Astro.redirect('/');
const { Content } = await article.render();

const allArticles = await getCollection('articles');

// Articles similaires : même sport en priorité, sinon même catégorie
const similar = allArticles
  .filter(a => a.slug !== slug)
  .map(a => ({
    article: a,
    score: (a.data.sport === article.data.sport ? 3 : 0) +
           (a.data.category === article.data.category ? 2 : 0)
  }))
  .filter(x => x.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(x => x.article);

const gradients: Record<string, string> = {
  mma:          'linear-gradient(135deg, #0F172A 0%, #1E88E5 100%)',
  boxe:         'linear-gradient(135deg, #7f1d1d 0%, #DC2626 100%)',
  kickboxing:   'linear-gradient(135deg, #064e3b 0%, #10B981 100%)',
  'muay-thai':  'linear-gradient(135deg, #78350f 0%, #F59E0B 100%)',
  grappling:    'linear-gradient(135deg, #1e3a8a 0%, #3B82F6 100%)',
  karate:       'linear-gradient(135deg, #1a1a2e 0%, #e94560 100%)',
  sanda:        'linear-gradient(135deg, #7c2d12 0%, #ea580c 100%)',
  lethwei:      'linear-gradient(135deg, #1c1917 0%, #a8a29e 100%)',
  savate:       'linear-gradient(135deg, #1e3a5f 0%, #2563EB 100%)',
  sambo:        'linear-gradient(135deg, #1a1a1a 0%, #dc2626 100%)',
  k1:           'linear-gradient(135deg, #1a1a2e 0%, #7C3AED 100%)',
  equipement:   'linear-gradient(135deg, #0F172A 0%, #38BDF8 100%)',
};
const catLabel: Record<string, string> = {
  'guide-debutant': 'Guide Débutant', 'conseil-entrainement': 'Conseil',
  'guide-equipement': 'Équipement', 'analyse': 'Analyse', 'actualite': 'Actualité', 'guide': 'Guide',
};

const sportLabel: Record<string, string> = {
  mma: 'MMA', boxe: 'Boxe', kickboxing: 'Kickboxing', 'muay-thai': 'Muay Thaï',
  grappling: 'Grappling', karate: 'Karaté', sanda: 'Sanda', lethwei: 'Lethwei',
  savate: 'Savate', sambo: 'Sambo', k1: 'K-1 / Glory', equipement: 'Équipement',
};
// Sports avec bannière photo PNG réelle
const sportImages: Record<string, string> = {
  mma:          '/images/banners/mma.png',
  boxe:         '/images/banners/boxe.png',
  'muay-thai':  '/images/banners/muay-thai.png',
  grappling:    '/images/banners/grappling.png',
  karate:       '/images/banners/karate.png',
  kickboxing:   '/images/banners/kickboxing.png',
  lethwei:      '/images/banners/lethwei.png',
  sambo:        '/images/banners/sambo.png',
  sanda:        '/images/banners/sanda.png',
  savate:       '/images/banners/savate.png',
  // k1 → utilise kickboxing (même discipline)
  k1:           '/images/banners/kickboxing.png',
};

// Détection des articles de comparaison (ex: kickboxing-vs-muay-thai)
function getComparisonImage(slugStr: string): string | null {
  const s = slugStr.toLowerCase();
  const hasKick = s.includes('kickboxing') || s.includes('k-1') || s.includes('k1');
  const hasMuay = s.includes('muay-thai') || s.includes('muay_thai') || s.includes('muaythai');
  if (hasKick && hasMuay) return '/images/banners/muay-thai-vs-kickboxing.png';
  return null;
}
// heroImage : '' si pas de bannière → affiche seulement le gradient (propre)
const heroImage = getComparisonImage(slug) || sportImages[article.data.sport] || '';

const siteUrl = 'https://fightfocus.fr';
const articleUrl = `${siteUrl}/articles/${slug}`;
const cleanTitle = article.data.title.replace(/<[^>]+>/g, '');

// Discipline page URL — k1 redirige vers kickboxing
const autresDisciplines = ['karate','sanda','lethwei','savate','sambo'];
const disciplineUrl = article.data.sport === 'k1'
  ? '/discipline/kickboxing'
  : ['mma','boxe','kickboxing','muay-thai','grappling'].includes(article.data.sport)
  ? `/discipline/${article.data.sport}`
  : autresDisciplines.includes(article.data.sport)
  ? `/autres-disciplines`
  : `/guides`;

// OG image : préférer og-[sport].png si dispo, sinon og-default.png
const ogImages: Record<string, string> = {
  mma:         '/images/og/og-mma.png',
  boxe:        '/images/og/og-boxe.png',
  kickboxing:  '/images/og/og-kickboxing.png',
  'muay-thai': '/images/og/og-muay-thai.png',
  grappling:   '/images/og/og-grappling.png',
  karate:      '/images/og/og-karate.png',
  sanda:       '/images/og/og-sanda.png',
  lethwei:     '/images/og/og-lethwei.png',
  savate:      '/images/og/og-savate.png',
  sambo:       '/images/og/og-sambo.png',
  k1:          '/images/og/og-k1.png',
};
const articleOgImage = ogImages[article.data.sport] || '/og-default.png';

const sportLabelsForSeo: Record<string, string> = {
  mma: 'MMA', boxe: 'Boxe', kickboxing: 'Kickboxing', 'muay-thai': 'Muay Thaï',
  grappling: 'Grappling', karate: 'Karaté', sanda: 'Sanda', lethwei: 'Lethwei',
  savate: 'Savate', sambo: 'Sambo', k1: 'K-1',
};
const catLabelsForSeo: Record<string, string> = {
  'guide': 'Guide', 'guide-debutant': 'Guide débutant', 'conseil-entrainement': 'Conseil entraînement',
  'guide-equipement': 'Guide équipement', 'analyse': 'Analyse', 'actualite': 'Actualité',
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": cleanTitle,
  "description": article.data.excerpt,
  "url": articleUrl,
  "datePublished": article.data.date,
  "dateModified": article.data.date,
  "image": {
    "@type": "ImageObject",
    "url": `${siteUrl}${articleOgImage}`,
    "width": 1200,
    "height": 630
  },
  "author": {
    "@type": "Person",
    "name": "Frédéric Laviemienandy",
    "url": `${siteUrl}/a-propos`
  },
  "publisher": {
    "@type": "Organization",
    "name": "FightFocus",
    "url": siteUrl,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/images/fightfocus-logo.png`,
      "width": 200,
      "height": 60
    }
  },
  "keywords": [
    sportLabelsForSeo[article.data.sport] || article.data.sport,
    catLabelsForSeo[article.data.category] || article.data.category,
    "sports de combat",
    "arts martiaux",
    "FightFocus"
  ].join(', '),
  "inLanguage": "fr-FR",
  "isAccessibleForFree": true,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl
  }
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": sportLabel[article.data.sport] || article.data.sport, "item": `${siteUrl}${disciplineUrl}` },
    { "@type": "ListItem", "position": 3, "name": cleanTitle, "item": articleUrl },
  ]
};

// Encodage pour partage social
const shareTitle = encodeURIComponent(cleanTitle);
const shareUrl = encodeURIComponent(articleUrl);
const twitterUrl = `https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}&via=fightfocus_fr`;
const whatsappUrl = `https://wa.me/?text=${shareTitle}%20${shareUrl}`;
const fbUrl      = `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`;
const redditUrl  = `https://www.reddit.com/submit?url=${shareUrl}&title=${shareTitle}`;
const telegramUrl = `https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`;
---
<Base
  title={`${cleanTitle} — FightFocus`}
  description={article.data.excerpt}
  ogImage={articleOgImage}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={article.data.date} />
    <meta property="article:modified_time" content={article.data.date} />
    <meta property="article:author" content="Frédéric Laviemienandy" />
    <meta property="article:section" content={article.data.sport} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

<!-- Barre de progression de lecture -->
<div id="reading-progress" style="position:fixed;top:0;left:0;height:3px;width:0%;background:var(--blue);z-index:9999;transition:width 0.1s linear;border-radius:0 2px 2px 0;"></div>

<div id="app">
  <div class="article-wrap">
    <div class="art-main">

      <!-- Fil d'Ariane -->
      <nav class="breadcrumb" aria-label="Fil d'Ariane" style="display:flex;align-items:center;gap:6px;font-size:0.8rem;color:var(--text-muted);margin-bottom:16px;flex-wrap:wrap;">
        <a href="/" style="color:var(--text-muted);text-decoration:none;hover:color:var(--blue);">Accueil</a>
        <span>›</span>
        <a href={disciplineUrl} style="color:var(--text-muted);text-decoration:none;">{sportLabel[article.data.sport] || article.data.sport}</a>
        <span>›</span>
        <span style="color:var(--text-light);max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title={cleanTitle}>{cleanTitle}</span>
      </nav>

      <!-- AdSense haut -->
      <div class="ad-slot ad-leader" style="margin-bottom:24px;"></div>

      <!-- Header article -->
      <div class="art-image-hero" style={`background:${gradients[article.data.sport] || 'linear-gradient(135deg,#0F172A,#38BDF8)'};height:260px;border-radius:14px;margin-bottom:28px;position:relative;overflow:hidden;`}>
        {heroImage && (
          <div style={`position:absolute;inset:0;background-image:url('${heroImage}');background-size:cover;background-position:center top;`}></div>
        )}
        <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.08) 0%, rgba(0,0,0,0.28) 100%);"></div>
      </div>

      <div class="art-tags">
        <span class="art-tag">{sportLabel[article.data.sport] || article.data.sport}</span>
        <span class="art-tag">{catLabel[article.data.category] || article.data.category}</span>
      </div>

      <h1 class="art-h1" set:html={article.data.title}></h1>
      <p class="art-lead">{article.data.excerpt}</p>

      <div class="art-meta-row">
        <span><strong>{article.data.date}</strong></span>
        <span id="reading-time"><span id="rt-val">...</span> min de lecture</span>
      </div>

      <!-- Table des matières (générée par JS) -->
      <div id="toc-container" style="display:none;" class="toc-box">
        <div class="toc-title">Sommaire</div>
        <ul id="toc-list" style="list-style:none;padding:0;margin:0;"></ul>
      </div>

      <div class="art-content" id="article-content">
        <Content />
      </div>

      <!-- Boutons de partage social -->
      <div style="margin-top:36px;padding:22px 26px;background:var(--card);border:1px solid var(--border);border-radius:14px;">
        <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--text-muted);margin-bottom:14px;">Partager cet article</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
          <a href={twitterUrl} target="_blank" rel="noopener noreferrer" title="Twitter / X" style="display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border-radius:50px;font-size:0.8rem;font-weight:700;text-decoration:none;background:#000;color:#fff;transition:opacity .15s;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Twitter / X
          </a>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" title="WhatsApp" style="display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border-radius:50px;font-size:0.8rem;font-weight:700;text-decoration:none;background:#25D366;color:#fff;transition:opacity .15s;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a8.8 8.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={fbUrl} target="_blank" rel="noopener noreferrer" title="Facebook" style="display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border-radius:50px;font-size:0.8rem;font-weight:700;text-decoration:none;background:#1877F2;color:#fff;transition:opacity .15s;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
          <a href={telegramUrl} target="_blank" rel="noopener noreferrer" title="Telegram" style="display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border-radius:50px;font-size:0.8rem;font-weight:700;text-decoration:none;background:#2AABEE;color:#fff;transition:opacity .15s;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            Telegram
          </a>
          <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" title="LinkedIn" style="display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border-radius:50px;font-size:0.8rem;font-weight:700;text-decoration:none;background:#0A66C2;color:#fff;transition:opacity .15s;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <button onclick="copyLink()" id="copy-btn" title="Copier le lien" style="display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border-radius:50px;font-size:0.8rem;font-weight:700;background:#E2E8F0;color:#0F172A;border:none;cursor:pointer;font-family:inherit;transition:opacity .15s;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            Copier le lien
          </button>
        </div>
      </div>

      <!-- AdSense bas -->
      <div class="ad-slot ad-leader" style="margin-top:40px;"></div>

      <!-- Articles similaires -->
      {similar.length > 0 && (
        <div style="margin-top:40px;">
          <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:14px;">Articles similaires</div>
          <div style="display:flex;flex-direction:column;gap:0;border:1px solid var(--border);border-radius:10px;overflow:hidden;">
            {similar.map((a, i) => (
              <a href={`/articles/${a.slug}`} class="similar-item" style={i < similar.length - 1 ? 'border-bottom:1px solid var(--border);' : ''}>
                <div style={`width:44px;height:44px;border-radius:7px;background:${gradients[a.data.sport] || gradients.mma};flex-shrink:0;overflow:hidden;position:relative;${(getComparisonImage(a.slug) || sportImages[a.data.sport]) ? `background-image:url('${getComparisonImage(a.slug) || sportImages[a.data.sport]}');background-size:cover;background-position:center;` : ''}`}></div>
                <div style="flex:1;min-width:0;">
                  <div class="similar-title" set:html={a.data.title}></div>
                  <div style="font-size:0.75rem;color:var(--text-muted);margin-top:2px;">{sportLabel[a.data.sport] || a.data.sport} · {a.data.date}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    <aside class="art-sidebar">
      <div class="nl-widget">
        <div class="widget-head">Newsletter</div>
        <p>Les meilleurs articles chaque semaine. Gratuit.</p>
        <input class="nl-input" type="email" id="nl-email" placeholder="votre@email.com" />
        <button class="nl-btn" onclick="subscribeNewsletter()">S'abonner</button>
        <div id="nl-feedback" style="font-size:0.8rem;margin-top:8px;min-height:1.2em;"></div>
      </div>

      <!-- Widget navigation interne SEO -->
      <div class="widget" style="margin-top:20px;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;">
        <div class="widget-head" style="font-weight:700;margin-bottom:12px;font-size:0.9rem;">Explorer FightFocus</div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;">
          <li><a href="/discipline/mma" style="color:var(--blue);text-decoration:none;font-size:0.87rem;">MMA / UFC</a></li>
          <li><a href="/discipline/boxe" style="color:var(--blue);text-decoration:none;font-size:0.87rem;">Boxe anglaise</a></li>
          <li><a href="/discipline/muay-thai" style="color:var(--blue);text-decoration:none;font-size:0.87rem;">Muay Thaï</a></li>
          <li><a href="/discipline/grappling" style="color:var(--blue);text-decoration:none;font-size:0.87rem;">Grappling / BJJ</a></li>
          <li><a href="/autres-disciplines" style="color:var(--blue);text-decoration:none;font-size:0.87rem;">Kickboxing & Autres</a></li>
          <li><a href="/guides" style="color:var(--blue);text-decoration:none;font-size:0.87rem;">Guides débutants</a></li>
          <li><a href="/equipement" style="color:var(--blue);text-decoration:none;font-size:0.87rem;">Équipement</a></li>
          <li><a href="/classements" style="color:var(--blue);text-decoration:none;font-size:0.87rem;">Classements UFC</a></li>
        </ul>
      </div>

      <!-- Widget discipline -->
      <div class="widget" style="margin-top:20px;">
        <div class="widget-head">{sportLabel[article.data.sport] || 'Discipline'}</div>
        <div class="widget-body">
          <a href={disciplineUrl} style="display:inline-flex;align-items:center;gap:8px;padding:10px 16px;background:var(--blue);color:#fff;border-radius:8px;text-decoration:none;font-size:0.85rem;font-weight:600;width:100%;justify-content:center;">
            Voir tous les articles →
          </a>
        </div>
      </div>

      <div class="ad-slot ad-rect" style="margin-top:20px;"></div>
    </aside>
  </div>
</div>
</Base>

<script>
// ── Barre de progression ────────────────────────────────
function updateProgress() {
  const bar = document.getElementById('reading-progress');
  if (!bar) return;
  const content = document.getElementById('article-content');
  if (!content) return;
  const rect = content.getBoundingClientRect();
  const contentHeight = content.offsetHeight;
  const scrolled = Math.max(0, -rect.top);
  const pct = Math.min(100, (scrolled / contentHeight) * 100);
  bar.style.width = pct + '%';
}
window.addEventListener('scroll', updateProgress, { passive: true });

// ── Temps de lecture ───────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  const content = document.getElementById('article-content');
  const rtVal = document.getElementById('rt-val');
  if (content && rtVal) {
    const words = content.innerText.trim().split(/\s+/).length;
    const mins = Math.max(1, Math.round(words / 220));
    rtVal.textContent = mins.toString();
  }

  // ── Table des matières automatique ────────────────
  const headings = content ? content.querySelectorAll('h2, h3') : [];
  const tocContainer = document.getElementById('toc-container');
  const tocList = document.getElementById('toc-list');
  if (headings.length >= 3 && tocContainer && tocList) {
    headings.forEach((h, i) => {
      const id = `heading-${i}`;
      h.id = id;
      const li = document.createElement('li');
      li.className = 'toc-item';
      const a = document.createElement('a');
      a.href = '#' + id;
      a.textContent = h.textContent || '';
      a.style.cssText = `
        color:var(--text-light);font-size:0.85rem;text-decoration:none;
        padding-left:${h.tagName === 'H3' ? '16px' : '0'};
        display:block;transition:color .2s;
      `;
      a.addEventListener('mouseover', () => a.style.color = 'var(--blue)');
      a.addEventListener('mouseout', () => a.style.color = 'var(--text-light)');
      li.appendChild(a);
      tocList.appendChild(li);
    });
    tocContainer.style.display = 'block';
  }
});

// ── Copier le lien ─────────────────────────────────────
function copyLink() {
  const btn = document.getElementById('copy-btn');
  navigator.clipboard.writeText(window.location.href).then(() => {
    if (btn) { btn.textContent = 'Copié !'; setTimeout(() => btn.textContent = 'Copier le lien', 2000); }
  });
}

// ── Newsletter Brevo ───────────────────────────────────
async function subscribeNewsletter() {
  const emailEl = document.getElementById('nl-email') as HTMLInputElement;
  const fb = document.getElementById('nl-feedback');
  const email = emailEl?.value?.trim();

  if (!email || !email.includes('@')) {
    if (fb) { fb.textContent = 'Email invalide'; fb.style.color = '#ef4444'; }
    return;
  }

  if (fb) { fb.textContent = 'Inscription en cours…'; fb.style.color = '#94a3b8'; }

  try {
    const res = await fetch('https://api.brevo.com/v3/contacts', {
      method: 'POST',
      headers: {
        'Accept': 'application/json',
        'Content-Type': 'application/json',
        'api-key': 'BREVO_API_KEY_PLACEHOLDER' // ← Remplacez par votre clé API Brevo (gratuit sur brevo.com)
      },
      body: JSON.stringify({
        email: email,
        listIds: [2], // ID de la liste Brevo — à ajuster dans votre compte
        updateEnabled: true,
        attributes: { SOURCE: 'FightFocus Article' }
      })
    });

    if (res.ok || res.status === 204) {
      if (fb) { fb.textContent = '✓ Inscrit ! À bientôt dans ta boîte mail.'; fb.style.color = '#10b981'; }
      if (emailEl) emailEl.value = '';
    } else if (res.status === 400) {
      // Le contact existe peut-être déjà
      if (fb) { fb.textContent = '✓ Déjà inscrit — on se retrouve prochainement !'; fb.style.color = '#10b981'; }
    } else {
      throw new Error('API error ' + res.status);
    }
  } catch (err) {
    if (fb) { fb.textContent = 'Erreur — réessaie dans quelques instants.'; fb.style.color = '#ef4444'; }
  }
}

// Exposer pour onclick inline
(window as any).copyLink = copyLink;
(window as any).subscribeNewsletter = subscribeNewsletter;
</script>
