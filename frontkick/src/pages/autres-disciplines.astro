---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

// Articles des disciplines "autres" (kickboxing + k1 + les 6 autres)
const autresSports = ['kickboxing', 'k1', 'sanda', 'lethwei', 'savate', 'sambo', 'karate'];
const autresArticles = allArticles
  .filter(a => autresSports.includes(a.data.sport))
  .sort((a, b) => {
    const da = new Date(a.data.date).getTime() || 0;
    const db = new Date(b.data.date).getTime() || 0;
    return db - da;
  });

const disciplines = [
  { slug: "kickboxing", label: "Kickboxing",           emoji: "🥊", desc: "Full contact, low kick, point fighting — la frappe debout",  gradient: "linear-gradient(135deg,#064e3b,#10B981)" },
  { slug: "k1",         label: "K-1 / Glory",          emoji: "⚡", desc: "Le kickboxing de haut niveau, frappes pures",                gradient: "linear-gradient(135deg,#1a1a2e,#7C3AED)" },
  { slug: "karate",     label: "Karaté",                emoji: "🥋", desc: "Kata, kumite et philosophie martiale",                       gradient: "linear-gradient(135deg,#1a1a2e,#e94560)" },
  { slug: "sanda",      label: "Sanda",                 emoji: "🐉", desc: "Le kickboxing chinois avec projections",                     gradient: "linear-gradient(135deg,#7c2d12,#ea580c)" },
  { slug: "savate",     label: "Savate Boxe Française", emoji: "🇫🇷", desc: "L'art du pied et du poing, made in France",                gradient: "linear-gradient(135deg,#1e3a5f,#2563EB)" },
  { slug: "sambo",      label: "Sambo",                 emoji: "🇷🇺", desc: "L'art martial russe de Khabib et Fedor",                   gradient: "linear-gradient(135deg,#1a1a1a,#dc2626)" },
  { slug: "lethwei",    label: "Lethwei",               emoji: "💀", desc: "L'art martial birman le plus brutal au monde",               gradient: "linear-gradient(135deg,#1c1917,#78716c)" },
];

const emojis: Record<string, string> = {
  mma: '🥊', boxe: '🥊', kickboxing: '🦵', 'muay-thai': '🦵',
  grappling: '🤼', karate: '🥋', equipement: '🛒', autres: '🥋',
};
const sportImages: Record<string, string> = {
  mma:          '/images/banners/mma.png',
  boxe:         '/images/banners/boxe.png',
  'muay-thai':  '/images/banners/muay-thai.png',
  grappling:    '/images/banners/grappling.png',
  karate:       '/images/banners/karate.png',
  kickboxing:   '/images/banners/kickboxing.png',
  lethwei:      '/images/banners/lethwei.png',
  sambo:        '/images/banners/sambo.png',
  sanda:        '/images/banners/sanda.png',
  savate:       '/images/banners/savate.png',
  k1:           '/images/banners/kickboxing.png',
};
const gradients: Record<string, string> = {
  kickboxing: 'linear-gradient(135deg, #064e3b 0%, #10B981 100%)',
  k1:         'linear-gradient(135deg, #1a1a2e 0%, #7C3AED 100%)',
  karate:     'linear-gradient(135deg, #1a1a2e 0%, #e94560 100%)',
  sanda:      'linear-gradient(135deg, #7c2d12 0%, #ea580c 100%)',
  lethwei:    'linear-gradient(135deg, #1c1917 0%, #a8a29e 100%)',
  savate:     'linear-gradient(135deg, #1e3a5f 0%, #2563EB 100%)',
  sambo:      'linear-gradient(135deg, #1a1a1a 0%, #dc2626 100%)',
};
const catLabel: Record<string, string> = {
  'guide-debutant': 'Guide Débutant', 'conseil-entrainement': 'Conseil',
  'guide-equipement': 'Équipement', 'analyse': 'Analyse', 'actualite': 'Actualité', 'guide': 'Guide',
};
---
<Base title="Autres disciplines — FightFocus" description="Découvrez tous les sports de combat : Kickboxing, K-1, Karaté, Sanda, Savate, Sambo, Lethwei.">
<div id="app">
  <div style="max-width:1100px; margin:0 auto; padding:0 16px;">

    <div class="list-hero">
      <h1>Autres disciplines</h1>
      <p>Kickboxing, K-1, Karaté et plus — tous les sports de combat hors des 4 grandes disciplines.</p>
    </div>

    <!-- Grille disciplines -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-bottom:48px;">
      {disciplines.map(d => (
        <a href={`/discipline/${d.slug}`} class="disc-bubble" style={`background:${d.gradient};`}>
          {sportImages[d.slug] && (
            <div class="disc-bubble__img">
              <img src={sportImages[d.slug]} alt={d.label} loading="lazy"/>
            </div>
          )}
          <div class="disc-bubble__overlay"></div>
          <div class="disc-bubble__content">
            <div style="font-family:'Bebas Neue',sans-serif;font-size:1.7rem;color:white;letter-spacing:.05em;line-height:1;">{d.label}</div>
            <div style="font-size:0.82rem;color:rgba(255,255,255,0.7);line-height:1.5;margin-top:6px;">{d.desc}</div>
            <div style="margin-top:12px;font-size:0.75rem;color:rgba(255,255,255,0.5);font-weight:700;letter-spacing:.06em;text-transform:uppercase;">Voir les articles →</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Articles récents des autres disciplines -->
    {autresArticles.length > 0 && (
      <div style="margin-bottom:48px;">
        <div class="sec-bar" style="margin-bottom:20px;">
          <h2 style="font-size:1.15rem;margin:0;font-weight:700;">Articles récents</h2>
          <div class="sec-line"></div>
        </div>
        <div class="art-grid">
          {autresArticles.map(a => (
            <a href={`/articles/${a.slug}`} class="art-card">
              <div class="art-image" style={sportImages[a.data.sport] ? `background-image:url('${sportImages[a.data.sport]}'),${gradients[a.data.sport] || 'linear-gradient(135deg,#1a1a2e,#4B5563)'};background-size:cover,cover;background-position:center top,center;position:relative;overflow:hidden;` : `background-image:${gradients[a.data.sport] || 'linear-gradient(135deg,#1a1a2e,#4B5563)'};position:relative;overflow:hidden;`}>
                <span class="art-cat-tag">{catLabel[a.data.category] || a.data.category}</span>
              </div>
              <div class="art-body">
                <div class="art-title-sm" set:html={a.data.title}></div>
                <div class="art-excerpt">{a.data.excerpt}</div>
                <div class="art-foot">
                  <span>{a.data.date}</span>
                  <span class="atype t-guide">{a.data.sport}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</div>
<style>
.disc-bubble {
  position: relative;
  border-radius: 14px;
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  min-height: 180px;
  transition: transform .2s, box-shadow .2s;
  border: 1px solid rgba(255,255,255,0.06);
}
.disc-bubble:hover { transform: translateY(-4px); box-shadow: 0 14px 40px rgba(0,0,0,.45); }
.disc-bubble__img {
  position: absolute;
  inset: 0;
}
.disc-bubble__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.55;
}
.disc-bubble__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
}
.disc-bubble__content {
  position: relative;
  z-index: 1;
  padding: 20px 22px;
  margin-top: auto;
}
</style>
</Base>
