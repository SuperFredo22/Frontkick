---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles');
function parseDate(d: string): number {
  const parsed = new Date(d);
  if (!isNaN(parsed.getTime())) return parsed.getTime();
  const y = d?.match(/\d{4}/);
  return y ? parseInt(y[0]) * 1000000 : 0;
}
const articles = all
  .filter(a => a.data.category === 'guide-equipement' || a.data.sport === 'equipement')
  .sort((a, b) => {
    if (b.data.featured !== a.data.featured) return (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0);
    return parseDate(b.data.date) - parseDate(a.data.date);
  });

const gradients: Record<string, string> = {
  mma: 'linear-gradient(135deg, #0F172A 0%, #1E88E5 100%)',
  boxe: 'linear-gradient(135deg, #7f1d1d 0%, #DC2626 100%)',
  kickboxing: 'linear-gradient(135deg, #064e3b 0%, #10B981 100%)',
  'muay-thai': 'linear-gradient(135deg, #78350f 0%, #F59E0B 100%)',
  grappling: 'linear-gradient(135deg, #1e3a8a 0%, #3B82F6 100%)',
  karate: 'linear-gradient(135deg, #1a1a1a 0%, #4B5563 100%)',
  equipement: 'linear-gradient(135deg, #0F172A 0%, #38BDF8 100%)',
  autres: 'linear-gradient(135deg, #134e4a 0%, #0D9488 100%)',
};
const sportImages: Record<string, string> = {
  mma: '/images/sports/mma.svg', boxe: '/images/sports/boxe.svg',
  kickboxing: '/images/sports/kickboxing.svg', 'muay-thai': '/images/sports/muay-thai.svg',
  grappling: '/images/sports/grappling.svg', karate: '/images/sports/karate.svg',
  sambo: '/images/sports/sambo.svg', savate: '/images/sports/savate.svg',
  sanda: '/images/sports/sanda.svg', lethwei: '/images/sports/lethwei.svg',
  k1: '/images/sports/k1.svg',
};

// Liens affiliés Amazon par catégorie (à remplacer par vos vrais liens affiliés)
const affiliateLinks = [
  {
    label: "Gants de boxe",
    desc: "Gants d'entraînement et de compétition — toutes marques",
    url: "https://www.amazon.fr/s?k=gants+de+boxe&tag=VOTRE-TAG-20",
    cta: "Voir sur Amazon →",
  },
  {
    label: "Protège-tibias",
    desc: "Indispensable pour le muay thaï et le kickboxing",
    url: "https://www.amazon.fr/s?k=protege+tibias+muay+thai&tag=VOTRE-TAG-20",
    cta: "Voir sur Amazon →",
  },
  {
    label: "Sac de frappe",
    desc: "Sacs suspendus, sur pied et d'angle — pour la maison et la salle",
    url: "https://www.amazon.fr/s?k=sac+de+frappe&tag=VOTRE-TAG-20",
    cta: "Voir sur Amazon →",
  },
  {
    label: "Shorts MMA / Muay Thaï",
    desc: "Shorts de combat pour l'entraînement et la compétition",
    url: "https://www.amazon.fr/s?k=short+mma+muay+thai&tag=VOTRE-TAG-20",
    cta: "Voir sur Amazon →",
  },
  {
    label: "Protège-dents",
    desc: "Protection buccale pour tous les sports de contact",
    url: "https://www.amazon.fr/s?k=protege+dents+boxe&tag=VOTRE-TAG-20",
    cta: "Voir sur Amazon →",
  },
  {
    label: "Corde à sauter",
    desc: "Cardio, coordination et endurance — outil de base du boxeur",
    url: "https://www.amazon.fr/s?k=corde+a+sauter+boxe&tag=VOTRE-TAG-20",
    cta: "Voir sur Amazon →",
  },
];
---
<Base title="Équipement Sports de Combat — FightFocus" description="Guides d'achat, comparatifs et recommandations d'équipement pour les sports de combat — boxe, MMA, muay thaï, kickboxing, grappling.">
<div id="app">
  <div class="list-page">

    <!-- Hero -->
    <div class="discipline-hero" style="background:linear-gradient(135deg,#0F172A 0%,#0369a1 100%);margin-bottom:32px;">
      <img src="/images/sports/boxe.svg" class="discipline-hero__bg" loading="eager" alt=""/>
      <div class="discipline-hero__overlay"></div>
      <div class="discipline-hero__content">
        <div class="discipline-hero__label">FightFocus</div>
        <h1 class="discipline-hero__title">Équipement</h1>
        <p class="discipline-hero__desc">Le bon matériel pour chaque discipline — sélection vérifiée, liens affiliés Amazon.</p>
      </div>
    </div>

    <!-- Grille affiliés Amazon -->
    <div style="margin-bottom:48px;">
      <div class="sec-bar" style="margin-bottom:20px;">
        <h2 style="font-size:1.15rem;margin:0;font-weight:700;">Acheter sur Amazon</h2>
        <div class="sec-line"></div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;">
        {affiliateLinks.map(item => (
          <a href={item.url} target="_blank" rel="noopener noreferrer sponsored" class="aff-card" style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-md);padding:20px;display:flex;flex-direction:column;gap:10px;text-decoration:none;transition:transform .2s,box-shadow .2s,border-color .2s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='var(--shadow-md)';this.style.borderColor='var(--blue)'" onmouseout="this.style.transform='';this.style.boxShadow='';this.style.borderColor=''">
            <div style="font-size:1.05rem;font-weight:700;color:var(--text);">{item.label}</div>
            <div style="font-size:0.83rem;color:var(--text-light);line-height:1.5;flex:1;">{item.desc}</div>
            <div style="font-size:0.8rem;color:var(--blue);font-weight:700;margin-top:4px;">{item.cta}</div>
          </a>
        ))}
      </div>
      <p style="font-size:0.75rem;color:var(--text-muted);margin-top:12px;">* Liens affiliés — en tant que Partenaire Amazon, nous percevons une commission sur les achats qualifiés, sans surcoût pour vous.</p>
    </div>

    <!-- Articles équipement -->
    {articles.length > 0 && (
      <div>
        <div class="sec-bar" style="margin-bottom:20px;">
          <h2 style="font-size:1.15rem;margin:0;font-weight:700;">Guides d'équipement</h2>
          <div class="sec-line"></div>
        </div>
        <div class="art-grid">
          {articles.map(a => (
            <a href={`/articles/${a.slug}`} class="art-card">
              <div class="art-image" style={`background:${gradients[a.data.sport] || gradients.equipement};position:relative;overflow:hidden;`}>
                <img src={sportImages[a.data.sport] ?? '/images/sports/default.svg'} alt={a.data.sport} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.8;" loading="lazy"/>
                <span class="art-cat-tag">Équipement</span>
              </div>
              <div class="art-body">
                <div class="art-title-sm" set:html={a.data.title}></div>
                <div class="art-excerpt">{a.data.excerpt}</div>
                <div class="art-foot">
                  <span>{a.data.date}</span>
                  <span class="atype t-guide">Guide</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {articles.length === 0 && (
      <p style="color:var(--text-muted);text-align:center;padding:2rem;">Aucun article équipement pour le moment — revenez bientôt !</p>
    )}

  </div>
</div>
</Base>
