---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles');
function parseDate(d: string): number {
  const parsed = new Date(d);
  if (!isNaN(parsed.getTime())) return parsed.getTime();
  const y = d?.match(/\d{4}/);
  return y ? parseInt(y[0]) * 1000000 : 0;
}
const articles = all
  .filter(a => a.data.category === 'guide-equipement' || a.data.sport === 'equipement')
  .sort((a, b) => {
    if (b.data.featured !== a.data.featured) return (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0);
    return parseDate(b.data.date) - parseDate(a.data.date);
  });

const gradients: Record<string, string> = {
  mma: 'linear-gradient(135deg, #0F172A 0%, #1E88E5 100%)',
  boxe: 'linear-gradient(135deg, #7f1d1d 0%, #DC2626 100%)',
  kickboxing: 'linear-gradient(135deg, #064e3b 0%, #10B981 100%)',
  'muay-thai': 'linear-gradient(135deg, #78350f 0%, #F59E0B 100%)',
  grappling: 'linear-gradient(135deg, #1e3a8a 0%, #3B82F6 100%)',
  karate: 'linear-gradient(135deg, #1a1a1a 0%, #4B5563 100%)',
  equipement: 'linear-gradient(135deg, #0F172A 0%, #38BDF8 100%)',
  autres: 'linear-gradient(135deg, #134e4a 0%, #0D9488 100%)',
};
const sportImages: Record<string, string> = {
  mma: '/images/sports/mma.svg', boxe: '/images/sports/boxe.svg',
  kickboxing: '/images/sports/kickboxing.svg', 'muay-thai': '/images/sports/muay-thai.svg',
  grappling: '/images/sports/grappling.svg', karate: '/images/sports/karate.svg',
  sambo: '/images/sports/sambo.svg', savate: '/images/sports/savate.svg',
  sanda: '/images/sports/sanda.svg', lethwei: '/images/sports/lethwei.svg',
  k1: '/images/sports/k1.svg',
};

---
<Base title="Équipement Sports de Combat — FightFocus" description="Guides d'achat, comparatifs et recommandations d'équipement pour les sports de combat — boxe, MMA, muay thaï, kickboxing, grappling.">
<div id="app">
  <div class="list-page">

    <!-- Hero -->
    <div class="discipline-hero" style="background:linear-gradient(135deg,#0F172A 0%,#0369a1 100%);margin-bottom:32px;">
      <div class="discipline-hero__bg" style="background-image:url('/images/sports/boxe.svg');"></div>
      <div class="discipline-hero__overlay"></div>
      <div class="discipline-hero__content">
        <div class="discipline-hero__label">FightFocus</div>
        <h1 class="discipline-hero__title">Équipement</h1>
        <p class="discipline-hero__desc">Le bon matériel pour chaque discipline — sélection vérifiée par nos experts.</p>
      </div>
    </div>

    <!-- Articles équipement -->
    {articles.length > 0 && (
      <div>
        <div class="sec-bar" style="margin-bottom:20px;">
          <h2 style="font-size:1.15rem;margin:0;font-weight:700;">Guides d'équipement</h2>
          <div class="sec-line"></div>
        </div>
        <div class="art-grid">
          {articles.map(a => (
            <a href={`/articles/${a.slug}`} class="art-card">
              <div class="art-image" style={`background:${gradients[a.data.sport] || gradients.equipement};position:relative;overflow:hidden;`}>
                <img src={sportImages[a.data.sport] ?? '/images/sports/default.svg'} alt={a.data.sport} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.8;" loading="lazy"/>
                <span class="art-cat-tag">Équipement</span>
              </div>
              <div class="art-body">
                <div class="art-title-sm" set:html={a.data.title}></div>
                <div class="art-excerpt">{a.data.excerpt}</div>
                <div class="art-foot">
                  <span>{a.data.date}</span>
                  <span class="atype t-guide">Guide</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {articles.length === 0 && (
      <p style="color:var(--text-muted);text-align:center;padding:2rem;">Aucun article équipement pour le moment — revenez bientôt !</p>
    )}

  </div>
</div>
</Base>
