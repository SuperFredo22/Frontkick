---
import Base from '../layouts/Base.astro';
---
<Base title="Contact — Front Kick" description="Contactez l'équipe Front Kick pour toute question, collaboration ou partenariat.">
<div id="app">
  <div style="max-width:680px; margin:0 auto;">
    <div class="list-hero">
      <h1>✉️ Contact</h1>
      <p>Une question, un partenariat, une suggestion d'article ?</p>
    </div>

    <div style="background:var(--card); border:1px solid var(--border); border-radius:16px; padding:36px; margin-bottom:24px;">

      <div style="display:grid; gap:20px; margin-bottom:32px;">
        <div style="background:var(--bg); border:1px solid var(--border); border-radius:12px; padding:20px; display:flex; gap:16px; align-items:flex-start;">
          <span style="font-size:1.8rem;">📧</span>
          <div>
            <div style="font-weight:700; margin-bottom:4px;">Email général</div>
            <a href="mailto:contact@frontkick.fr" style="color:var(--blue);">contact@frontkick.fr</a>
          </div>
        </div>
        <div style="background:var(--bg); border:1px solid var(--border); border-radius:12px; padding:20px; display:flex; gap:16px; align-items:flex-start;">
          <span style="font-size:1.8rem;">🤝</span>
          <div>
            <div style="font-weight:700; margin-bottom:4px;">Partenariats & affiliation</div>
            <a href="mailto:partenariat@frontkick.fr" style="color:var(--blue);">partenariat@frontkick.fr</a>
            <p style="font-size:0.83rem; color:var(--text-light); margin-top:6px;">Marques, équipementiers, programmes d'affiliation.</p>
          </div>
        </div>
        <div style="background:var(--bg); border:1px solid var(--border); border-radius:12px; padding:20px; display:flex; gap:16px; align-items:flex-start;">
          <span style="font-size:1.8rem;">✍️</span>
          <div>
            <div style="font-weight:700; margin-bottom:4px;">Proposer un article</div>
            <p style="font-size:0.83rem; color:var(--text-light); margin-top:4px;">Vous êtes pratiquant ou coach ? Proposez-nous un article invité à <a href="mailto:redaction@frontkick.fr" style="color:var(--blue);">redaction@frontkick.fr</a></p>
          </div>
        </div>
      </div>

      <div style="background:var(--blue-tint); border:1px solid rgba(30,136,229,.2); border-radius:12px; padding:20px;">
        <div style="font-weight:700; margin-bottom:8px; color:var(--blue);">⏱ Délai de réponse</div>
        <p style="font-size:0.88rem; color:var(--text-light);">Nous répondons généralement sous <strong>48h ouvrées</strong>. Pour les demandes urgentes, précisez-le dans l'objet de votre email.</p>
      </div>
    </div>
  </div>
</div>
</Base>
