const menDivisions = Object.entries(rankings).filter(([,v]) => v.gender === "men");
const womenDivisions = Object.entries(rankings).filter(([,v]) => v.gender === "women");
---
<Base title="Classements UFC — Front Kick" description="Classements UFC à jour par catégorie de poids. Toutes les divisions hommes et femmes.">
<div id="app">
  <div style="max-width:1200px; margin:0 auto; padding:0 16px;">

    <div class="list-hero">
      <h1>🏆 Classements UFC</h1>
      <p>Classements officiels par catégorie — Top 5 challengers + Champion. Mis à jour mars 2026.</p>
    </div>

    <!-- HOMMES -->
    <div style="margin-bottom:40px;">
      <h2 style="font-family:'Bebas Neue',sans-serif; font-size:1.8rem; letter-spacing:.06em; color:var(--blue-light); margin-bottom:20px; display:flex; align-items:center; gap:10px;">
        ♂️ Divisions masculines
      </h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px;">
        {menDivisions.map(([category, data]) => (
          <div style={`background:var(--card); border:1px solid var(--border); border-radius:16px; overflow:hidden;`}>
            <div style={`background:${data.gradient}; padding:14px 20px; display:flex; align-items:center; gap:10px;`}>
              <span style="font-size:1.4rem;">{data.emoji}</span>
              <span style="font-family:'Bebas Neue',sans-serif; font-size:1.15rem; color:white; letter-spacing:.05em;">{category}</span>
            </div>
            {data.fighters.map((f, i) => (
              <div style={`display:flex; align-items:center; gap:12px; padding:11px 18px; ${i < data.fighters.length-1 ? 'border-bottom:1px solid var(--border);' : ''} ${f.rank === 'C' ? 'background:rgba(245,158,11,.07);' : ''}`}>
                <div style={`min-width:34px; text-align:center; font-family:'Barlow Condensed',sans-serif; font-size:0.95rem; font-weight:700; ${f.rank === 'C' ? 'color:#F59E0B;' : 'color:var(--text-light);'}`}>
                  {f.rank === 'C' ? '🏆' : `#${f.rank}`}
                </div>
                <div style="flex:1;">
                  <div style={`font-weight:700; font-size:0.9rem; ${f.rank === 'C' ? 'color:#F59E0B;' : ''}`}>
                    {f.country} {f.name}
                    {f.rank === 'C' && <span style="font-size:0.65rem; background:#F59E0B; color:#000; border-radius:4px; padding:1px 5px; margin-left:6px; font-weight:800;">CHAMP</span>}
                  </div>
                  <div style="font-size:0.75rem; color:var(--text-light);">{f.record}</div>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <!-- FEMMES -->
    <div style="margin-bottom:48px;">
      <h2 style="font-family:'Bebas Neue',sans-serif; font-size:1.8rem; letter-spacing:.06em; color:#e879f9; margin-bottom:20px; display:flex; align-items:center; gap:10px;">
        ♀️ Divisions féminines
      </h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px;">
        {womenDivisions.map(([category, data]) => (
          <div style={`background:var(--card); border:1px solid var(--border); border-radius:16px; overflow:hidden;`}>
            <div style={`background:${data.gradient}; padding:14px 20px; display:flex; align-items:center; gap:10px;`}>
              <span style="font-size:1.4rem;">{data.emoji}</span>
              <span style="font-family:'Bebas Neue',sans-serif; font-size:1.15rem; color:white; letter-spacing:.05em;">{category}</span>
            </div>
            {data.fighters.map((f, i) => (
              <div style={`display:flex; align-items:center; gap:12px; padding:11px 18px; ${i < data.fighters.length-1 ? 'border-bottom:1px solid var(--border);' : ''} ${f.rank === 'C' ? 'background:rgba(232,121,249,.07);' : ''}`}>
                <div style={`min-width:34px; text-align:center; font-family:'Barlow Condensed',sans-serif; font-size:0.95rem; font-weight:700; ${f.rank === 'C' ? 'color:#e879f9;' : 'color:var(--text-light);'}`}>
                  {f.rank === 'C' ? '👑' : `#${f.rank}`}
                </div>
                <div style="flex:1;">
                  <div style={`font-weight:700; font-size:0.9rem; ${f.rank === 'C' ? 'color:#e879f9;' : ''}`}>
                    {f.country} {f.name}
                    {f.rank === 'C' && <span style="font-size:0.65rem; background:#e879f9; color:#000; border-radius:4px; padding:1px 5px; margin-left:6px; font-weight:800;">CHAMP</span>}
                  </div>
                  <div style="font-size:0.75rem; color:var(--text-light);">{f.record}</div>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <!-- Note -->
    <div style="background:var(--card); border:1px solid var(--border); border-radius:12px; padding:14px 18px; margin-bottom:48px; font-size:0.82rem; color:var(--text-light); display:flex; gap:10px; align-items:flex-start;">
      <span style="font-size:1.1rem; flex-shrink:0;">ℹ️</span>
      <span>Classements mis à jour manuellement à partir de <a href="https://www.ufc.com/rankings" target="_blank" rel="noopener" style="color:var(--blue);">ufc.com/rankings</a>. Dernière mise à jour : <strong>Mars 2026</strong>. Les classements UFC sont officiellement mis à jour chaque semaine après chaque événement.</span>
    </div>

  </div>
</div>
</Base>
