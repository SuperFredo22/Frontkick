const menDivisions   = Object.entries(rankings).filter(([,v]) => v.gender === "men");
const womenDivisions = Object.entries(rankings).filter(([,v]) => v.gender === "women");
---
<Base title="Classements UFC — Front Kick" description="Classements UFC officiels à jour par catégorie de poids. Toutes les divisions hommes et femmes.">
<div id="app">
  <div style="max-width:1200px; margin:0 auto; padding:0 16px;">

    <div class="list-hero">
      <h1>🏆 Classements UFC</h1>
      <p>Source officielle : <a href="https://www.ufc.com/rankings" target="_blank" rel="noopener" style="color:var(--blue);">ufc.com/rankings</a> — Mise à jour UFC : <strong>17 mars 2026</strong></p>
    </div>

    <!-- HOMMES -->
    <div style="margin-bottom:40px;">
      <h2 style="font-family:'Bebas Neue',sans-serif; font-size:1.8rem; letter-spacing:.06em; color:var(--blue-light); margin-bottom:20px;">♂️ Divisions masculines</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px;">
        {menDivisions.map(([category, data]) => (
          <div style="background:var(--card); border:1px solid var(--border); border-radius:16px; overflow:hidden;">
            <div style={`background:${data.gradient}; padding:14px 20px;`}>
              <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
                <span style="font-size:1.2rem;">{data.emoji}</span>
                <span style="font-family:'Bebas Neue',sans-serif; font-size:1.1rem; color:white; letter-spacing:.05em;">{category}</span>
              </div>
              <div style="font-size:0.78rem; color:rgba(255,255,255,.6); letter-spacing:.04em; text-transform:uppercase;">
                Champion : <strong style="color:rgba(255,255,255,.9);">{data.champion}</strong>
              </div>
            </div>
            {data.fighters.map((f, i) => (
              <div style={`display:flex; align-items:center; gap:12px; padding:10px 18px; ${i < data.fighters.length-1 ? 'border-bottom:1px solid var(--border);' : ''}`}>
                <div style="min-width:32px; text-align:center; font-family:'Barlow Condensed',sans-serif; font-size:0.9rem; font-weight:700; color:var(--text-light);">
                  #{f.rank}
                </div>
                <div style="flex:1;">
                  <div style="font-weight:700; font-size:0.88rem;">
                    {f.country} {f.name}
                    {f.note && <span style="font-size:0.62rem; background:#F59E0B; color:#000; border-radius:4px; padding:1px 5px; margin-left:5px; font-weight:800;">{f.note}</span>}
                  </div>
                  <div style="font-size:0.73rem; color:var(--text-light);">{f.record}</div>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <!-- FEMMES -->
    <div style="margin-bottom:48px;">
      <h2 style="font-family:'Bebas Neue',sans-serif; font-size:1.8rem; letter-spacing:.06em; color:#e879f9; margin-bottom:20px;">♀️ Divisions féminines</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px;">
        {womenDivisions.map(([category, data]) => (
          <div style="background:var(--card); border:1px solid var(--border); border-radius:16px; overflow:hidden;">
            <div style={`background:${data.gradient}; padding:14px 20px;`}>
              <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
                <span style="font-size:1.2rem;">{data.emoji}</span>
                <span style="font-family:'Bebas Neue',sans-serif; font-size:1.1rem; color:white; letter-spacing:.05em;">{category}</span>
              </div>
              <div style="font-size:0.78rem; color:rgba(255,255,255,.6); letter-spacing:.04em; text-transform:uppercase;">
                Champion : <strong style="color:rgba(255,255,255,.9);">{data.champion}</strong>
              </div>
            </div>
            {data.fighters.map((f, i) => (
              <div style={`display:flex; align-items:center; gap:12px; padding:10px 18px; ${i < data.fighters.length-1 ? 'border-bottom:1px solid var(--border);' : ''}`}>
                <div style="min-width:32px; text-align:center; font-family:'Barlow Condensed',sans-serif; font-size:0.9rem; font-weight:700; color:var(--text-light);">
                  #{f.rank}
                </div>
                <div style="flex:1;">
                  <div style="font-weight:700; font-size:0.88rem;">{f.country} {f.name}</div>
                  <div style="font-size:0.73rem; color:var(--text-light);">{f.record}</div>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <div style="background:var(--card); border:1px solid var(--border); border-radius:12px; padding:14px 18px; margin-bottom:48px; font-size:0.82rem; color:var(--text-light); display:flex; gap:10px; align-items:flex-start;">
      <span style="font-size:1.1rem; flex-shrink:0;">ℹ️</span>
      <span>Classements mis à jour manuellement depuis <a href="https://www.ufc.com/rankings" target="_blank" rel="noopener" style="color:var(--blue);">ufc.com/rankings</a>. Dernière maj UFC : <strong>Mardi 17 mars 2026</strong>. Les classements officiels UFC sont mis à jour après chaque événement.</span>
    </div>

  </div>
</div>
</Base>
