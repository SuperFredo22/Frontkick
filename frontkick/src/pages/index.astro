---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

// ── Tri robuste par date décroissante ──────────────────────────────────────
function parseDate(s: string): number {
  if (!s) return 0;
  const d = new Date(s);
  if (!isNaN(d.getTime())) return d.getTime();
  const y = s.match(/\d{4}/);
  return y ? parseInt(y[0]) * 1_000_000 : 0;
}

const sorted = [...allArticles].sort((a, b) =>
  parseDate(b.data.date) - parseDate(a.data.date)
);

// ── À la une : dernière actualité, sinon premier article ───────────────────
const featuredArticle =
  sorted.find(a => a.data.category === 'actualite') ?? sorted[0];

// ── Actualités récentes (sidebar hero + section) ───────────────────────────
const latestNews = sorted
  .filter(a => a.data.category === 'actualite' && a.slug !== featuredArticle?.slug)
  .slice(0, 5);

// ── Sections par discipline ────────────────────────────────────────────────
const mmaArticles        = sorted.filter(a => a.data.sport === 'mma').slice(0, 3);
const boxeArticles       = sorted.filter(a => a.data.sport === 'boxe').slice(0, 3);
const kickboxingArticles = sorted.filter(a => a.data.sport === 'kickboxing').slice(0, 3);
const muayThaiArticles   = sorted.filter(a => a.data.sport === 'muay-thai').slice(0, 3);
const grapplingArticles  = sorted.filter(a => a.data.sport === 'grappling').slice(0, 3);

// ── Guides (non-actualité) ─────────────────────────────────────────────────
const guides = sorted.filter(a => a.data.category !== 'actualite').slice(0, 4);

// ── Sidebar hero : 4 actus après la une ───────────────────────────────────
const sidebar = latestNews.slice(0, 4);

// ── Section "Dernières publications" : 6 articles hors une ────────────────
const recent = sorted.filter(a => a.slug !== featuredArticle?.slug).slice(0, 6);

// ── Données d'affichage ────────────────────────────────────────────────────
const gradients: Record<string, string> = {
  mma:         'linear-gradient(135deg, #0F172A 0%, #1E88E5 100%)',
  boxe:        'linear-gradient(135deg, #7f1d1d 0%, #DC2626 100%)',
  kickboxing:  'linear-gradient(135deg, #064e3b 0%, #10B981 100%)',
  'muay-thai': 'linear-gradient(135deg, #78350f 0%, #F59E0B 100%)',
  grappling:   'linear-gradient(135deg, #1e3a8a 0%, #3B82F6 100%)',
  karate:      'linear-gradient(135deg, #1a1a1a 0%, #4B5563 100%)',
  equipement:  'linear-gradient(135deg, #0F172A 0%, #38BDF8 100%)',
  autres:      'linear-gradient(135deg, #134e4a 0%, #0D9488 100%)',
  sanda:       'linear-gradient(135deg, #7c2d12 0%, #ea580c 100%)',
  lethwei:     'linear-gradient(135deg, #1c1917 0%, #a8a29e 100%)',
  savate:      'linear-gradient(135deg, #1e3a5f 0%, #2563EB 100%)',
  sambo:       'linear-gradient(135deg, #1a1a1a 0%, #dc2626 100%)',
  k1:          'linear-gradient(135deg, #1a1a2e 0%, #7C3AED 100%)',
};
const emojis: Record<string, string> = {
  mma: '🥊', boxe: '🥊', kickboxing: '🦵', 'muay-thai': '🦵',
  grappling: '🤼', karate: '🥋', equipement: '🛒', autres: '🥋',
  sanda: '🐉', lethwei: '💀', savate: '🇫🇷', sambo: '🇷🇺', k1: '⚡',
};
const catLabel: Record<string, string> = {
  'guide-debutant':       'Guide Débutant',
  'conseil-entrainement': 'Conseil',
  'guide-equipement':     'Équipement',
  'analyse':              'Analyse',
  'actualite':            'Actualité',
  'guide':               'Guide',
};
const sportLabel: Record<string, string> = {
  mma: 'MMA', boxe: 'Boxe', kickboxing: 'Kickboxing', 'muay-thai': 'Muay-Thaï',
  grappling: 'Grappling', karate: 'Karaté', sanda: 'Sanda', lethwei: 'Lethwei',
  savate: 'Savate', sambo: 'Sambo', k1: 'K-1',
};

const disciplineCards = [
  { key: 'mma',        name: 'MMA',           emoji: '🥊', origin: 'Mixed Martial Arts · Mondial' },
  { key: 'boxe',       name: 'Boxe anglaise',  emoji: '🥊', origin: 'Boxing · Grande-Bretagne' },
  { key: 'kickboxing', name: 'Kickboxing',     emoji: '🦵', origin: 'Full contact · USA / Japon' },
  { key: 'muay-thai',  name: 'Muay-Thaï',      emoji: '🦵', origin: 'Art martial · Thaïlande' },
  { key: 'grappling',  name: 'Grappling',      emoji: '🤼', origin: 'BJJ · Judo · Wrestling · Sambo' },
  { key: 'guides',     name: 'Guides',         emoji: '📖', origin: 'Débutant · Intermédiaire · Avancé' },
];

const sportImages: Record<string, string> = {
  mma:          '/images/banners/mma.png',
  boxe:         '/images/banners/boxe.png',
  'muay-thai':  '/images/banners/muay-thai.png',
  grappling:    '/images/banners/grappling.png',
  karate:       '/images/banners/karate.png',
  guides:       '/images/banners/guide.png',
  // kickboxing, savate, sambo, sanda, lethwei, k1 → gradient seul (pas de bannière encore)
};

// ── SEO : description dynamique basée sur la une ──────────────────────────
const seoDesc = featuredArticle
  ? `FightFocus — ${featuredArticle.data.excerpt ?? featuredArticle.data.title}`
  : 'FightFocus — Le média français des sports de combat : MMA, Boxe, Muay Thai, Kickboxing, Grappling.';
---
<Base title="FightFocus - MMA, Boxe, Muay Thai : Actu, Guides et Analyses" description={seoDesc}>
<div id="app">

  <!-- HERO : À LA UNE + SIDEBAR ACTUS -->
  {featuredArticle && (
  <div class="hero">
    <a href={`/articles/${featuredArticle.slug}`} class="featured-card">
      <div class="featured-image" style={`background: ${gradients[featuredArticle.data.sport] ?? gradients.mma}; background-image: url('${sportImages[featuredArticle.data.sport] ?? ''}'); background-size: cover; background-position: center;`}>
        <span class="fi-badge">À la une</span>
      </div>
      <div class="featured-body">
        <div class="feat-meta">
          <span>{catLabel[featuredArticle.data.category] ?? featuredArticle.data.category}</span>
          <span>{featuredArticle.data.date}</span>
        </div>
        <h1 class="feat-h1" set:html={featuredArticle.data.title}></h1>
        <p class="feat-desc">{featuredArticle.data.excerpt}</p>
        <div class="feat-footer"><span class="read-more">Lire l'article →</span></div>
      </div>
    </a>

    {sidebar.length > 0 && (
    <div class="hero-sidebar">
      {sidebar.map(a => (
        <a href={`/articles/${a.slug}`} class="mini-card">
          <div>
            <div class="mini-cat">{sportLabel[a.data.sport] ?? a.data.sport} · {catLabel[a.data.category] ?? a.data.category}</div>
            <div class="mini-title" set:html={a.data.title}></div>
            <div class="mini-date">{a.data.date}</div>
          </div>
        </a>
      ))}
    </div>
    )}
  </div>
  )}

  <!-- DISCIPLINES -->
  <div class="sec-bar">
    <h2>Disciplines</h2>
    <div class="sec-line"></div>
  </div>
  <div class="sports-hub">
    {disciplineCards.map(d => (
      <a href={d.key === 'guides' ? '/guides' : `/discipline/${d.key}`} class="sport-hub-card" style={`background: ${gradients[d.key] || gradients.mma};`}>
        <div class="sport-hub-img" style={`background-image:url('${sportImages[d.key] ?? '/images/banners/mma.png'}');background-size:cover;background-position:center;`}></div>
        <div class="sport-hub-top">
          <div>
            <div class="sport-name">{d.name}</div>
            <div class="sport-origin">{d.origin}</div>
          </div>
        </div>
        <div class="sport-links">
          <div class="sport-link"><span>Articles</span></div>
          <div class="sport-link"><span>Guide →</span></div>
        </div>
      </a>
    ))}
  </div>

  <!-- DERNIÈRES ACTUALITÉS -->
  {latestNews.length > 0 && (
  <div class="main-layout">
    <main>
      <div class="sec-bar">
        <h2>Dernières actualités</h2>
        <div class="sec-line"></div>
        <a href="/discipline/mma" class="see-all">Toutes les actus →</a>
      </div>
      <div class="art-grid">
        {latestNews.map(a => (
          <a href={`/articles/${a.slug}`} class="art-card">
            <div class="art-image" style={`background: ${gradients[a.data.sport] ?? gradients.mma}; background-image: url('${sportImages[a.data.sport] ?? ''}'); background-size: cover; background-position: center; position:relative; overflow:hidden;`}>
              <span class="art-cat-tag">Actualité</span>
            </div>
            <div class="art-body">
              <div class="art-title-sm" set:html={a.data.title}></div>
              <div class="art-excerpt">{a.data.excerpt}</div>
              <div class="art-foot">
                <span>{a.data.date}</span>
                <span class="atype t-actu">{sportLabel[a.data.sport] ?? a.data.sport}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>

    <aside class="sidebar-col">
      <div class="nl-widget">
        <div class="widget-head">Newsletter hebdo</div>
        <p>Les meilleurs articles de la semaine. Gratuit.</p>
        <input class="nl-input" type="email" id="nl-email-home" placeholder="votre@email.com" />
        <button class="nl-btn" onclick="subscribeHome()">S'abonner</button>
        <div id="nl-feedback-home" style="font-size:0.8rem;margin-top:8px;min-height:1.2em;"></div>
      </div>
      <div class="widget">
        <div class="widget-head">Prochains événements</div>
        <div class="widget-body">
          <div class="ev-item"><div class="ev-date">12 Avr</div><div>UFC 314 — Miami</div></div>
          <div class="ev-item"><div class="ev-date">10 Mai</div><div>UFC 315 — Montréal</div></div>
          <div class="ev-item"><div class="ev-date">06 Sep</div><div>UFC Paris 2026</div></div>
        </div>
      </div>
      <div class="ad-slot ad-rect"></div>
    </aside>
  </div>
  )}

  <!-- GUIDES & ANALYSES -->
  {guides.length > 0 && (
  <div class="sec-bar" style="margin-top:2.5rem;">
    <h2>Guides & Analyses</h2>
    <div class="sec-line"></div>
    <a href="/guides" class="see-all">Voir tous les guides →</a>
  </div>
  )}
  {guides.length > 0 && (
  <div class="art-grid" style="padding:0 1.5rem 2rem;">
    {guides.map(a => (
      <a href={`/articles/${a.slug}`} class="art-card">
        <div class="art-image" style={`background: ${gradients[a.data.sport] ?? gradients.mma}; background-image: url('${sportImages[a.data.sport] ?? ''}'); background-size: cover; background-position: center; position:relative; overflow:hidden;`}>
          <span class="art-cat-tag">{catLabel[a.data.category] ?? a.data.category}</span>
        </div>
        <div class="art-body">
          <div class="art-title-sm" set:html={a.data.title}></div>
          <div class="art-excerpt">{a.data.excerpt}</div>
          <div class="art-foot">
            <span>{a.data.date}</span>
            <span class="atype t-guide">{sportLabel[a.data.sport] ?? a.data.sport}</span>
          </div>
        </div>
      </a>
    ))}
  </div>
  )}

  <!-- SECTIONS PAR SPORT -->
  {mmaArticles.length > 0 && (
  <div style="margin-top:2.5rem;">
    <div class="sec-bar">
      <h2>MMA</h2>
      <div class="sec-line"></div>
      <a href="/discipline/mma" class="see-all">Tous les articles MMA →</a>
    </div>
    <div class="art-grid">
      {mmaArticles.map(a => (
        <a href={`/articles/${a.slug}`} class="art-card">
          <div class="art-image" style={`background:${gradients.mma};background-image:url('${sportImages.mma}');background-size:cover;background-position:center;position:relative;overflow:hidden;`}>
            <span class="art-cat-tag">{catLabel[a.data.category] ?? a.data.category}</span>
          </div>
          <div class="art-body">
            <div class="art-title-sm" set:html={a.data.title}></div>
            <div class="art-excerpt">{a.data.excerpt}</div>
            <div class="art-foot"><span>{a.data.date}</span></div>
          </div>
        </a>
      ))}
    </div>
  </div>
  )}

  {boxeArticles.length > 0 && (
  <div style="margin-top:2.5rem;">
    <div class="sec-bar">
      <h2>Boxe</h2>
      <div class="sec-line"></div>
      <a href="/discipline/boxe" class="see-all">Tous les articles Boxe →</a>
    </div>
    <div class="art-grid">
      {boxeArticles.map(a => (
        <a href={`/articles/${a.slug}`} class="art-card">
          <div class="art-image" style={`background:${gradients.boxe};background-image:url('${sportImages.boxe}');background-size:cover;background-position:center;position:relative;overflow:hidden;`}>
            <span class="art-cat-tag">{catLabel[a.data.category] ?? a.data.category}</span>
          </div>
          <div class="art-body">
            <div class="art-title-sm" set:html={a.data.title}></div>
            <div class="art-excerpt">{a.data.excerpt}</div>
            <div class="art-foot"><span>{a.data.date}</span></div>
          </div>
        </a>
      ))}
    </div>
  </div>
  )}

  {muayThaiArticles.length > 0 && (
  <div style="margin-top:2.5rem;">
    <div class="sec-bar">
      <h2>Muay Thaï</h2>
      <div class="sec-line"></div>
      <a href="/discipline/muay-thai" class="see-all">Tous les articles Muay Thaï →</a>
    </div>
    <div class="art-grid">
      {muayThaiArticles.map(a => (
        <a href={`/articles/${a.slug}`} class="art-card">
          <div class="art-image" style={`background:${gradients['muay-thai']};background-image:url('${sportImages['muay-thai']}');background-size:cover;background-position:center;position:relative;overflow:hidden;`}>
            <span class="art-cat-tag">{catLabel[a.data.category] ?? a.data.category}</span>
          </div>
          <div class="art-body">
            <div class="art-title-sm" set:html={a.data.title}></div>
            <div class="art-excerpt">{a.data.excerpt}</div>
            <div class="art-foot"><span>{a.data.date}</span></div>
          </div>
        </a>
      ))}
    </div>
  </div>
  )}

  {grapplingArticles.length > 0 && (
  <div style="margin-top:2.5rem;">
    <div class="sec-bar">
      <h2>Grappling</h2>
      <div class="sec-line"></div>
      <a href="/discipline/grappling" class="see-all">Tous les articles Grappling →</a>
    </div>
    <div class="art-grid">
      {grapplingArticles.map(a => (
        <a href={`/articles/${a.slug}`} class="art-card">
          <div class="art-image" style={`background:${gradients.grappling};background-image:url('${sportImages.grappling}');background-size:cover;background-position:center;position:relative;overflow:hidden;`}>
            <span class="art-cat-tag">{catLabel[a.data.category] ?? a.data.category}</span>
          </div>
          <div class="art-body">
            <div class="art-title-sm" set:html={a.data.title}></div>
            <div class="art-excerpt">{a.data.excerpt}</div>
            <div class="art-foot"><span>{a.data.date}</span></div>
          </div>
        </a>
      ))}
    </div>
  </div>
  )}

  <!-- DERNIÈRES PUBLICATIONS (fallback si peu d'articles) -->
  {latestNews.length === 0 && recent.length > 0 && (
  <div class="main-layout">
    <main>
      <div class="sec-bar">
        <h2>Dernières publications</h2>
        <div class="sec-line"></div>
        <a href="/guides" class="see-all">Voir tout →</a>
      </div>
      <div class="art-grid">
        {recent.map(a => (
          <a href={`/articles/${a.slug}`} class="art-card">
            <div class="art-image" style={`background: ${gradients[a.data.sport] ?? gradients.mma}; background-image: url('${sportImages[a.data.sport] ?? ''}'); background-size: cover; background-position: center; position:relative; overflow:hidden;`}>
              <span class="art-cat-tag">{catLabel[a.data.category] ?? a.data.category}</span>
            </div>
            <div class="art-body">
              <div class="art-title-sm" set:html={a.data.title}></div>
              <div class="art-excerpt">{a.data.excerpt}</div>
              <div class="art-foot">
                <span>{a.data.date}</span>
                <span class="atype t-guide">{catLabel[a.data.category] ?? a.data.category}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>

    <aside class="sidebar-col">
      <div class="nl-widget">
        <div class="widget-head">Newsletter hebdo</div>
        <p>Les meilleurs articles de la semaine. Gratuit.</p>
        <input class="nl-input" type="email" id="nl-email-home" placeholder="votre@email.com" />
        <button class="nl-btn" onclick="subscribeHome()">S'abonner</button>
        <div id="nl-feedback-home" style="font-size:0.8rem;margin-top:8px;min-height:1.2em;"></div>
      </div>
      <div class="widget">
        <div class="widget-head">Prochains événements</div>
        <div class="widget-body">
          <div class="ev-item"><div class="ev-date">12 Avr</div><div>UFC 314 — Miami</div></div>
          <div class="ev-item"><div class="ev-date">10 Mai</div><div>UFC 315 — Montréal</div></div>
          <div class="ev-item"><div class="ev-date">06 Sep</div><div>UFC Paris 2026</div></div>
        </div>
      </div>
      <div class="ad-slot ad-rect"></div>
    </aside>
  </div>
  )}

</div>

<script>
// ── Newsletter Brevo (page d'accueil) ──────────────────
async function subscribeHome() {
  const emailEl = document.getElementById('nl-email-home') as HTMLInputElement;
  const fb = document.getElementById('nl-feedback-home');
  const email = emailEl?.value?.trim();

  if (!email || !email.includes('@')) {
    if (fb) { fb.textContent = 'Email invalide'; fb.style.color = '#ef4444'; }
    return;
  }

  if (fb) { fb.textContent = 'Inscription en cours…'; fb.style.color = '#94a3b8'; }

  try {
    const res = await fetch('https://api.brevo.com/v3/contacts', {
      method: 'POST',
      headers: {
        'Accept': 'application/json',
        'Content-Type': 'application/json',
        'api-key': 'BREVO_API_KEY_PLACEHOLDER' // ← Remplacez par votre clé API Brevo (gratuit sur brevo.com)
      },
      body: JSON.stringify({
        email: email,
        listIds: [2], // ID de la liste Brevo — à ajuster dans votre compte
        updateEnabled: true,
        attributes: { SOURCE: 'FightFocus Accueil' }
      })
    });

    if (res.ok || res.status === 204) {
      if (fb) { fb.textContent = '✓ Inscrit ! À bientôt dans ta boîte mail.'; fb.style.color = '#10b981'; }
      if (emailEl) emailEl.value = '';
    } else if (res.status === 400) {
      // Le contact existe peut-être déjà
      if (fb) { fb.textContent = '✓ Déjà inscrit — on se retrouve prochainement !'; fb.style.color = '#10b981'; }
    } else {
      throw new Error('API error ' + res.status);
    }
  } catch (err) {
    if (fb) { fb.textContent = 'Erreur — réessaie dans quelques instants.'; fb.style.color = '#ef4444'; }
  }
}

(window as any).subscribeHome = subscribeHome;
</script>
</Base>
