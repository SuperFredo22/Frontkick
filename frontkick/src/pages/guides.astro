---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles');
function parseDate(d: string): number {
  const parsed = new Date(d);
  if (!isNaN(parsed.getTime())) return parsed.getTime();
  const y = d?.match(/\d{4}/);
  return y ? parseInt(y[0]) * 1000000 : 0;
}
const guides = all
  .filter(a => ['guide-debutant', 'guide-equipement', 'conseil-entrainement', 'guide', 'analyse'].includes(a.data.category))
  .sort((a, b) => {
    if (b.data.featured !== a.data.featured) return (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0);
    return parseDate(b.data.date) - parseDate(a.data.date);
  });

const gradients: Record<string, string> = {
  mma:          'linear-gradient(135deg, #0F172A 0%, #1E88E5 100%)',
  boxe:         'linear-gradient(135deg, #7f1d1d 0%, #DC2626 100%)',
  kickboxing:   'linear-gradient(135deg, #064e3b 0%, #10B981 100%)',
  'muay-thai':  'linear-gradient(135deg, #78350f 0%, #F59E0B 100%)',
  grappling:    'linear-gradient(135deg, #1e3a8a 0%, #3B82F6 100%)',
  karate:       'linear-gradient(135deg, #1a1a1a 0%, #4B5563 100%)',
  equipement:   'linear-gradient(135deg, #0F172A 0%, #38BDF8 100%)',
  autres:       'linear-gradient(135deg, #134e4a 0%, #0D9488 100%)',
  sanda:        'linear-gradient(135deg, #7c2d12 0%, #ea580c 100%)',
  lethwei:      'linear-gradient(135deg, #1c1917 0%, #a8a29e 100%)',
  savate:       'linear-gradient(135deg, #1e3a5f 0%, #2563EB 100%)',
  sambo:        'linear-gradient(135deg, #1a1a1a 0%, #dc2626 100%)',
  k1:           'linear-gradient(135deg, #1a1a2e 0%, #7C3AED 100%)',
};
const catLabel: Record<string, string> = {
  'guide-debutant':       'Guide Débutant',
  'guide-equipement':     'Équipement',
  'conseil-entrainement': 'Conseil',
  'guide':                'Guide',
  'analyse':              'Analyse',
  'actualite':            'Actualité',
};
const sportLabel: Record<string, string> = {
  mma: 'MMA', boxe: 'Boxe', kickboxing: 'Kickboxing', 'muay-thai': 'Muay Thaï',
  grappling: 'Grappling', karate: 'Karaté', equipement: 'Équipement', autres: 'Autres',
  sanda: 'Sanda', lethwei: 'Lethwei', savate: 'Savate', sambo: 'Sambo', k1: 'K-1',
};

// Sports disponibles parmi les guides
const sportsInGuides = [...new Set(guides.map(a => a.data.sport))].sort();
const guidesJSON = JSON.stringify(guides.map(a => ({
  slug: a.slug,
  title: a.data.title,
  excerpt: a.data.excerpt || '',
  sport: a.data.sport,
  category: a.data.category,
  date: a.data.date,
})));
const sportImages: Record<string, string> = {
  mma:          '/images/banners/mma.png',
  boxe:         '/images/banners/boxe.png',
  'muay-thai':  '/images/banners/muay-thai.png',
  grappling:    '/images/banners/grappling.png',
  karate:       '/images/banners/karate.png',
};
const gradientsJSON    = JSON.stringify(gradients);
const sportImagesJSON  = JSON.stringify(sportImages);
const catLabelJSON     = JSON.stringify(catLabel);
const sportLabelJSON   = JSON.stringify(sportLabel);
---
<Base title="Guides — FightFocus" description="Tous les guides pour débutants et pratiquants en sports de combat — débutant, équipement, entraînement.">
<div id="app">
  <div class="list-page">
    <div style="position:relative;height:280px;border-radius:14px;overflow:hidden;margin-bottom:36px;">
      <div style="position:absolute;inset:0;background-image:url('/images/banners/guide.png');background-size:cover;background-position:center top;"></div>
      <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.08) 55%, transparent 100%);"></div>
      <div style="position:absolute;bottom:0;left:0;padding:24px 28px;">
        <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.15em;color:rgba(255,255,255,0.5);margin-bottom:5px;">FightFocus</div>
        <h1 style="font-family:'Bebas Neue',sans-serif;font-size:2.8rem;letter-spacing:.04em;color:#fff;line-height:1;margin:0 0 6px;">Guides</h1>
        <p style="font-size:0.88rem;color:rgba(255,255,255,0.8);max-width:500px;line-height:1.5;margin:0;">Débuter, progresser, s'équiper — <strong id="guides-count">{guides.length}</strong> guides disponibles.</p>
      </div>
    </div>

    <!-- Filtres par sport -->
    <div class="filter-bar" id="filter-bar" style="margin-bottom:24px;">
      <button class="filter-btn active" data-sport="tous" onclick="filterGuides('tous',this)">Tous</button>
      {sportsInGuides.map(sport => (
        <button class="filter-btn" data-sport={sport} onclick={`filterGuides('${sport}',this)`}>
          {sportLabel[sport] || sport}
        </button>
      ))}
    </div>

    <div id="guides-grid" class="art-grid"></div>
    <div id="no-guides" style="display:none;text-align:center;padding:3rem;color:var(--text-muted);">Aucun guide pour ce filtre.</div>
  </div>
</div>
</Base>

<script define:vars={{ guidesJSON, gradientsJSON, sportImagesJSON, catLabelJSON, sportLabelJSON }}>
const guides = JSON.parse(guidesJSON);
const gradients = JSON.parse(gradientsJSON);
const sportImages = JSON.parse(sportImagesJSON);
const catLabel = JSON.parse(catLabelJSON);
const sportLabel = JSON.parse(sportLabelJSON);
const DEFAULT_GRAD = 'linear-gradient(135deg,#0F172A,#1E88E5)';

function renderCard(a) {
  const grad = gradients[a.sport] || DEFAULT_GRAD;
  const img = sportImages[a.sport] || '';
  const label = catLabel[a.category] || a.category;
  const sport = sportLabel[a.sport] || a.sport;
  // background-image multi-couche : pas de url('') qui écraserait le gradient
  const bgStyle = img
    ? `background-image:url('${img}'),${grad};background-size:cover,cover;background-position:center top,center;position:relative;overflow:hidden;`
    : `background-image:${grad};position:relative;overflow:hidden;`;
  return `
    <a href="/articles/${a.slug}" class="art-card">
      <div class="art-image" style="${bgStyle}">
        <span class="art-cat-tag">${label}</span>
      </div>
      <div class="art-body">
        <div class="art-title-sm">${a.title}</div>
        <div class="art-excerpt">${a.excerpt}</div>
        <div class="art-foot">
          <span>${a.date}</span>
          <span class="atype t-guide">${sport}</span>
        </div>
      </div>
    </a>`;
}

let currentSport = 'tous';

function filterGuides(sport, btn) {
  currentSport = sport;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  render();
}

function render() {
  const grid = document.getElementById('guides-grid');
  const noGuides = document.getElementById('no-guides');
  const count = document.getElementById('guides-count');
  const filtered = currentSport === 'tous'
    ? guides
    : guides.filter(a => a.sport === currentSport);
  if (count) count.textContent = filtered.length;
  if (filtered.length === 0) {
    grid.innerHTML = '';
    noGuides.style.display = 'block';
  } else {
    noGuides.style.display = 'none';
    grid.innerHTML = filtered.map(renderCard).join('');
  }
}

window.filterGuides = filterGuides;
render();
</script>
