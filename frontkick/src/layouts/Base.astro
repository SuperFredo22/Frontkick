---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = "Front Kick — Le Média des Sports de Combat",
  description = "Guides, analyses et actualités sur tous les sports de combat : MMA, boxe, kickboxing, muay thaï, sanda, lethwei et bien plus.",
  ogImage = "/og-default.png"
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = Astro.site ?? 'https://frontkick.vercel.app';
const canonicalURL = new URL(currentPath, siteUrl);
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0F172A" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={new URL(ogImage, siteUrl)} />
  <meta property="og:site_name" content="Front Kick" />
  <meta property="og:locale" content="fr_FR" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, siteUrl)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,400&family=DM+Serif+Display:ital@0;1&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />

  <!-- Google AdSense — se charge uniquement après consentement cookies -->
  <!-- ID à remplacer par votre vrai ca-pub-XXXXXXXXXX après validation AdSense -->
  <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXX" crossorigin="anonymous"></script> -->
</head>
<body>

<!-- HEADER -->
<header>
  <div class="header-top">
    <a href="/" class="logo">
      <img src="/images/frontkick-logo.png" alt="Front Kick" />
    </a>
    <div class="header-actions">
      <form id="searchForm" action="/recherche" method="get">
        <input type="text" id="searchInput" name="q" placeholder="Rechercher…" aria-label="Rechercher un article" />
        <button type="submit" id="searchBtn" aria-label="Lancer la recherche">🔍</button>
      </form>
      <button id="darkModeToggle" aria-label="Basculer mode sombre">🌙</button>
    </div>
  </div>
  <nav class="nav-bar" role="navigation" aria-label="Navigation principale">
    <div class="nav-inner">
      <a href="/" class={`nav-link ${currentPath === '/' ? 'active' : ''}`}>Accueil</a>

      <!-- Disciplines principales -->
      <a href="/discipline/mma"        class={`nav-link ${currentPath.includes('/mma') ? 'active' : ''}`}>MMA</a>
      <a href="/discipline/boxe"       class={`nav-link ${currentPath.includes('/boxe') ? 'active' : ''}`}>Boxe</a>
      <a href="/discipline/kickboxing" class={`nav-link ${currentPath.includes('/kickboxing') ? 'active' : ''}`}>Kickboxing</a>
      <a href="/discipline/muay-thai"  class={`nav-link ${currentPath.includes('/muay-thai') ? 'active' : ''}`}>Muay Thaï</a>
      <a href="/discipline/grappling"  class={`nav-link ${currentPath.includes('/grappling') ? 'active' : ''}`}>Grappling</a>

      <!-- Dropdown "Autres disciplines" — CSS hover pur -->
      <div class="nav-dropdown">
        <button class={`nav-link nav-dropdown-btn ${['/sanda','/lethwei','/savate','/sambo','/k1','/karate'].some(s => currentPath.includes(s)) ? 'active' : ''}`} tabindex="0" aria-haspopup="true">
          AUTRES ▾
        </button>
        <div class="nav-dropdown-menu" role="menu">
          <a href="/discipline/sanda" role="menuitem">🐉 Sanda</a>
          <a href="/discipline/lethwei" role="menuitem">💀 Lethwei</a>
          <a href="/discipline/savate" role="menuitem">🇫🇷 Savate</a>
          <a href="/discipline/sambo" role="menuitem">🇷🇺 Sambo</a>
          <a href="/discipline/k1" role="menuitem">⚡ K-1 / Glory</a>
          <a href="/discipline/karate" role="menuitem">🥋 Karaté</a>
        </div>
      </div>

      <a href="/guides"     class={`nav-link ${currentPath.startsWith('/guides') ? 'active' : ''}`}>Guides</a>
      <a href="/actualites" class={`nav-link ${currentPath.startsWith('/actualites') ? 'active' : ''}`}>Actualités</a>
      <a href="/classements" class={`nav-link ${currentPath.startsWith('/classements') ? 'active' : ''}`}>Classements</a>
    </div>
  </nav>
</header>

<div class="hero-accent-band"></div>

<slot />

<!-- Footer ad placeholder (activé après validation AdSense) -->
<div class="footer-ad">
  <div class="ad-slot ad-leader"></div>
</div>

<!-- FOOTER -->
<footer role="contentinfo">
  <div class="footer-inner">
    <div class="footer-brand">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:.05em;color:#fff;">
        Front<span style="color:#38BDF8;">Kick</span>
      </div>
      <p>Le média des sports de combat.<br/>Analyses, guides et équipement pour pratiquants et passionnés.</p>
    </div>
    <div class="footer-col">
      <h4>Disciplines</h4>
      <ul>
        <li><a href="/discipline/mma">MMA / UFC</a></li>
        <li><a href="/discipline/boxe">Boxe anglaise</a></li>
        <li><a href="/discipline/muay-thai">Muay-Thaï</a></li>
        <li><a href="/discipline/kickboxing">Kickboxing</a></li>
        <li><a href="/discipline/grappling">Grappling</a></li>
        <li><a href="/discipline/sanda">Sanda</a></li>
        <li><a href="/discipline/lethwei">Lethwei</a></li>
        <li><a href="/discipline/savate">Savate</a></li>
        <li><a href="/discipline/sambo">Sambo</a></li>
        <li><a href="/discipline/k1">K-1 / Glory</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Ressources</h4>
      <ul>
        <li><a href="/guides">Guides débutants</a></li>
        <li><a href="/equipement">Équipement</a></li>
        <li><a href="/actualites">Actualités</a></li>
        <li><a href="/classements">Classements UFC</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Le site</h4>
      <ul>
        <li><a href="/a-propos">À propos</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/mentions-legales">Mentions légales</a></li>
        <li><a href="/politique-confidentialite">Confidentialité</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2026 Front Kick · Tous droits réservés · Frédéric Laviemienandy</span>
    <span>* Liens affiliés — commission perçue sans surcoût pour vous.</span>
    <button class="cookie-manage-link" onclick="showCookieBanner()">Gérer mes cookies</button>
  </div>
</footer>

<!-- BANDEAU COOKIES RGPD -->
<div id="cookie-banner" style="display:none;" role="dialog" aria-label="Gestion des cookies">
  <p>
    🍪 Ce site utilise des cookies pour mesurer l'audience et afficher des publicités personnalisées (Google AdSense).
    En cliquant sur "Accepter", vous consentez à leur utilisation.
    <a href="/politique-confidentialite">En savoir plus</a>
  </p>
  <div class="cookie-actions">
    <button class="cookie-btn-refuse" onclick="refuseCookies()">Refuser</button>
    <button class="cookie-btn-accept" onclick="acceptCookies()">Accepter</button>
  </div>
</div>

<script>
  // ── Dark mode ──
  const toggle = document.getElementById('darkModeToggle');
  if (localStorage.getItem('darkMode') === 'true') {
    document.body.classList.add('dark-mode');
    if (toggle) (toggle as HTMLElement).textContent = '☀️';
  }
  if (toggle) {
    toggle.addEventListener('click', () => {
      document.body.classList.toggle('dark-mode');
      const isDark = document.body.classList.contains('dark-mode');
      (toggle as HTMLElement).textContent = isDark ? '☀️' : '🌙';
      localStorage.setItem('darkMode', String(isDark));
    });
  }

  // ── Cookies ──
  function showCookieBanner() {
    const banner = document.getElementById('cookie-banner');
    if (banner) banner.style.display = 'flex';
  }
  function acceptCookies() {
    localStorage.setItem('cookieConsent', 'accepted');
    hideBanner();
    loadAnalytics();
  }
  function refuseCookies() {
    localStorage.setItem('cookieConsent', 'refused');
    hideBanner();
  }
  function hideBanner() {
    const banner = document.getElementById('cookie-banner');
    if (banner) banner.style.display = 'none';
  }
  function loadAnalytics() {
    // À activer quand vous avez votre ID AdSense/Analytics
    // const s = document.createElement('script');
    // s.src = 'https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX';
    // document.head.appendChild(s);
  }
  window.addEventListener('DOMContentLoaded', () => {
    if (!localStorage.getItem('cookieConsent')) showCookieBanner();
  });
  (window as any).showCookieBanner = showCookieBanner;
  (window as any).acceptCookies = acceptCookies;
  (window as any).refuseCookies = refuseCookies;
</script>

</body>
</html>
