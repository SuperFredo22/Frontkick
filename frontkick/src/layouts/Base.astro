---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}
const {
  title = "FightFocus - MMA, Boxe, Muay Thai : Actu, Guides et Analyses",
  description = "FightFocus, le média des sports de combat : actualités MMA, analyses, guides boxe, muay-thai, kickboxing et arts martiaux.",
  ogImage = "/og-default.png",
  ogType = "website"
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = Astro.site ?? 'https://fightfocus.fr';
const canonicalURL = new URL(currentPath, siteUrl);
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="google-site-verification" content="s_3JA_wJFz2bQ93Se9Y7qfwhreJA5ZD1F6R04EeJeBc" />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="FightFocus" />
  <meta name="theme-color" content="#0F172A" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/images/fightfocus-logo.png" />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={new URL(ogImage, siteUrl)} />
  <meta property="og:site_name" content="FightFocus" />
  <meta property="og:locale" content="fr_FR" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@fightfocus_fr" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, siteUrl)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,400&family=DM+Serif+Display:ital@0;1&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />

  <slot name="head" />
  <!-- JSON-LD : WebSite + SearchAction -->
  <script type="application/ld+json" is:inline>{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "FightFocus",
    "url": "https://fightfocus.fr",
    "description": "FightFocus est le média dédié aux sports de combat : MMA, boxe, muay thai, analyses, guides et équipement.",
    "inLanguage": "fr-FR",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://fightfocus.fr/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    },
    "publisher": {
      "@type": "Organization",
      "name": "FightFocus",
      "url": "https://fightfocus.fr",
      "logo": {
        "@type": "ImageObject",
        "url": "https://fightfocus.fr/images/fightfocus-logo.png"
      }
    }
  }</script>

  <!-- Google Analytics 4 — se charge uniquement après consentement cookies -->
  <!-- Remplacez G-XXXXXXXXXX par votre vrai ID de mesure GA4 -->
  <!-- Pour obtenir votre ID : analytics.google.com → Admin → Flux de données → ID de mesure -->
  <script is:inline>
    window.GA_MEASUREMENT_ID = 'G-XXXXXXXXXX'; // ← Remplacer ici
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      'analytics_storage': 'denied'
    });
    // Si consentement déjà donné, charger GA immédiatement
    if (typeof window !== 'undefined' && localStorage.getItem('cookieConsent') === 'accepted') {
      gtag('consent', 'update', {'analytics_storage': 'granted'});
      (function(){
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + window.GA_MEASUREMENT_ID;
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', window.GA_MEASUREMENT_ID, {page_path: window.location.pathname});
      })();
    }
  </script>

  <!-- ═══════════════════════════════════════════════════════
       GOOGLE ADSENSE — Activer après validation du compte
       1. Aller sur : https://adsense.google.com
       2. Remplacer ca-pub-XXXXXXXXXX par votre vrai Publisher ID
       3. Décommenter la ligne ci-dessous
       ═══════════════════════════════════════════════════════ -->
  <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXX" crossorigin="anonymous"></script> -->
</head>
<body>

<!-- HEADER -->
<header>
  <div class="header-top">
    <a href="/" class="logo">
      <img src="/images/fightfocus-logo.png" alt="FightFocus" height="40" loading="eager" decoding="async" style="width:auto;" />
    </a>
    <div class="header-actions">
      <form id="searchForm" action="/search" method="get">
        <input type="text" id="searchInput" name="q" placeholder="Rechercher…" aria-label="Rechercher un article" />
        <button type="submit" id="searchBtn" aria-label="Lancer la recherche">🔍</button>
      </form>
      <button id="darkModeToggle" aria-label="Basculer mode sombre">🌙</button>
    </div>
  </div>
  <nav class="nav-bar" role="navigation" aria-label="Navigation principale">
    <div class="nav-inner">
      <a href="/" class={`nav-link ${currentPath === '/' ? 'active' : ''}`}>Accueil</a>

      <!-- Disciplines principales -->
      <a href="/discipline/mma"        class={`nav-link ${currentPath.includes('/mma') ? 'active' : ''}`}>MMA</a>
      <a href="/discipline/boxe"       class={`nav-link ${currentPath.includes('/boxe') ? 'active' : ''}`}>Boxe</a>
      <a href="/discipline/kickboxing" class={`nav-link ${currentPath.includes('/kickboxing') ? 'active' : ''}`}>Kickboxing</a>
      <a href="/discipline/muay-thai"  class={`nav-link ${currentPath.includes('/muay-thai') ? 'active' : ''}`}>Muay Thaï</a>
      <a href="/discipline/grappling"  class={`nav-link ${currentPath.includes('/grappling') ? 'active' : ''}`}>Grappling</a>

      <a href="/autres-disciplines" class={`nav-link ${currentPath.startsWith('/autres-disciplines') || ['/discipline/sanda','/discipline/lethwei','/discipline/savate','/discipline/sambo','/discipline/k1','/discipline/karate'].some(s => currentPath.startsWith(s)) ? 'active' : ''}`}>Autres</a>

      <a href="/guides"     class={`nav-link ${currentPath.startsWith('/guides') ? 'active' : ''}`}>Guides</a>
      <a href="/equipement"  class={`nav-link ${currentPath.startsWith('/equipement') ? 'active' : ''}`}>Équipement</a>
      <a href="/actualites" class={`nav-link ${currentPath.startsWith('/actualites') ? 'active' : ''}`}>Actualités</a>
      <a href="/classements" class={`nav-link ${currentPath.startsWith('/classements') ? 'active' : ''}`}>Classements</a>
    </div>
  </nav>
</header>

<div class="hero-accent-band"></div>

<slot />

<!-- Footer ad placeholder (activé après validation AdSense) -->
<div class="footer-ad">
  <div class="ad-slot ad-leader"></div>
</div>

<!-- FOOTER -->
<footer role="contentinfo">
  <div class="footer-inner">
    <div class="footer-brand">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:.05em;color:#fff;">
        Fight<span style="color:#38BDF8;">Focus</span>
      </div>
      <p>Le média des sports de combat.<br/>Analyses, guides et équipement pour pratiquants et passionnés.</p>
    </div>
    <div class="footer-col">
      <h4>Disciplines</h4>
      <ul>
        <li><a href="/discipline/mma">MMA / UFC</a></li>
        <li><a href="/discipline/boxe">Boxe anglaise</a></li>
        <li><a href="/discipline/muay-thai">Muay-Thaï</a></li>
        <li><a href="/discipline/kickboxing">Kickboxing</a></li>
        <li><a href="/discipline/grappling">Grappling</a></li>
        <li><a href="/discipline/sanda">Sanda</a></li>
        <li><a href="/discipline/lethwei">Lethwei</a></li>
        <li><a href="/discipline/savate">Savate</a></li>
        <li><a href="/discipline/sambo">Sambo</a></li>
        <li><a href="/discipline/k1">K-1 / Glory</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Ressources</h4>
      <ul>
        <li><a href="/guides">Guides débutants</a></li>
        <li><a href="/equipement">Équipement</a></li>
        <li><a href="/actualites">Actualités</a></li>
        <li><a href="/classements">Classements UFC</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Le site</h4>
      <ul>
        <li><a href="/a-propos">À propos</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/mentions-legales">Mentions légales</a></li>
        <li><a href="/politique-confidentialite">Confidentialité</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2026 FightFocus · Tous droits réservés · Frédéric Laviemienandy</span>
    <span>* Liens affiliés — commission perçue sans surcoût pour vous.</span>
    <button class="cookie-manage-link" onclick="showCookieBanner()">Gérer mes cookies</button>
  </div>
</footer>

<!-- BANDEAU COOKIES RGPD -->
<div id="cookie-banner" style="display:none;" role="dialog" aria-label="Gestion des cookies">
  <p>
    🍪 Ce site utilise des cookies pour mesurer l'audience et afficher des publicités personnalisées (Google AdSense).
    En cliquant sur "Accepter", vous consentez à leur utilisation.
    <a href="/politique-confidentialite">En savoir plus</a>
  </p>
  <div class="cookie-actions">
    <button class="cookie-btn-refuse" onclick="refuseCookies()">Refuser</button>
    <button class="cookie-btn-accept" onclick="acceptCookies()">Accepter</button>
  </div>
</div>

<script>
  // ── Dark mode ──
  const toggle = document.getElementById('darkModeToggle');
  if (localStorage.getItem('darkMode') === 'true') {
    document.body.classList.add('dark-mode');
    if (toggle) (toggle as HTMLElement).textContent = '☀️';
  }
  if (toggle) {
    toggle.addEventListener('click', () => {
      document.body.classList.toggle('dark-mode');
      const isDark = document.body.classList.contains('dark-mode');
      (toggle as HTMLElement).textContent = isDark ? '☀️' : '🌙';
      localStorage.setItem('darkMode', String(isDark));
    });
  }

  // ── Cookies ──
  function showCookieBanner() {
    const banner = document.getElementById('cookie-banner');
    if (banner) banner.style.display = 'flex';
  }
  function acceptCookies() {
    localStorage.setItem('cookieConsent', 'accepted');
    hideBanner();
    loadAnalytics();
  }
  function refuseCookies() {
    localStorage.setItem('cookieConsent', 'refused');
    hideBanner();
  }
  function hideBanner() {
    const banner = document.getElementById('cookie-banner');
    if (banner) banner.style.display = 'none';
  }
  function loadAnalytics() {
    if (!window.GA_MEASUREMENT_ID || window.GA_MEASUREMENT_ID === 'G-XXXXXXXXXX') return;
    if (window._gaLoaded) return;
    window._gaLoaded = true;
    // Mettre à jour le consentement GA4
    if (typeof gtag === 'function') {
      gtag('consent', 'update', {'analytics_storage': 'granted'});
    }
    // Charger le script GA4
    var s = document.createElement('script');
    s.async = true;
    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + window.GA_MEASUREMENT_ID;
    document.head.appendChild(s);
    s.onload = function() {
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', window.GA_MEASUREMENT_ID, {page_path: window.location.pathname});
    };
  }
  window.addEventListener('DOMContentLoaded', () => {
    if (!localStorage.getItem('cookieConsent')) showCookieBanner();
  });
  (window as any).showCookieBanner = showCookieBanner;
  (window as any).acceptCookies = acceptCookies;
  (window as any).refuseCookies = refuseCookies;
</script>


<style>
  @media (max-width: 768px) {
    body {
      overflow-x: hidden;
    }
    img.logo, header img {
      max-width: 160px;
      height: auto;
      display: block;
      margin: 0 auto;
    }
    nav, header nav {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
      padding: 8px;
    }
    nav a {
      font-size: 14px;
      padding: 6px 10px;
    }
    .card-grid, .grid {
      display: flex;
      flex-direction: column;
      gap: 16px;
      padding: 0 12px;
    }
    .card {
      width: 100%;
      box-sizing: border-box;
    }
    img {
      max-width: 100%;
      height: auto;
    }
    button, a.btn, .share-btn {
      min-height: 44px;
    }
  }
  @media (max-width: 1024px) {
    .card-grid, .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
</body>
</html>
